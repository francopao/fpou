def _read(sheet, **kw):
    return pd.read_excel(
        RUTA_ZODA, sheet_name=sheet,
        engine="openpyxl", dtype=object, **kw
    )


def cargar_bd():
    df = _read("BD", header=0)
    df["Fecha"] = pd.to_datetime(df["Fecha"], errors="coerce")
    df = df.dropna(subset=["Fecha"]).sort_values("Fecha").reset_index(drop=True)
    for c in df.columns[1:]:
        df[c] = pd.to_numeric(df[c], errors="coerce")
    # Reemplazar 0 por NaN en columnas Z (0 = sin dato, no Z = 0)
    z_cols = [c for c in df.columns if c.startswith("Z_") or c.endswith("Index")]
    df[z_cols] = df[z_cols].replace(0, np.nan)
    return df


def cargar_parametria():
    df = _read("Parametría", header=None)
    param = df.iloc[3:, 1:7].copy()
    param.columns = ["alias", "z_col", "basket_col", "bvl_col", "bbg_ticker", "sbs_code"]
    param = param.dropna(subset=["alias"]).reset_index(drop=True)
    param["alias"]      = param["alias"].astype(str).str.strip()
    param["z_col"]      = param["z_col"].astype(str).str.strip()
    param["basket_col"] = param["basket_col"].astype(str).str.strip()
    param["bvl_col"]    = param["bvl_col"].astype(str).str.strip()
    param["sbs_code"]   = param["sbs_code"].astype(str).str.strip()
    return param


def cargar_gics():
    df = _read("GICS", header=0)
    df = df[["BBG", "GICS", "Empresa"]].dropna(subset=["BBG"]).copy()
    df["BBG"]    = df["BBG"].astype(str).str.strip()
    df["GICS"]   = df["GICS"].astype(str).str.strip()
    df["Empresa"] = df["Empresa"].astype(str).str.strip()
    return df.set_index("BBG")


def cargar_posiciones():
    """Suma PxQ de Fondo1+2+3 para cada SBS en cada fecha disponible."""
    df = _read("DQ_IN", header=0)
    pxq = df[df["Dato"].astype(str) == "PxQ"].copy()
    pxq["Fecha"] = pd.to_datetime(pxq["Fecha"], errors="coerce")
    pxq = pxq.dropna(subset=["Fecha"])
    sbs_cols = list(df.columns[5:])

    records = []
    for fecha, grupo in pxq.groupby("Fecha"):
        row = {"Fecha": fecha}
        for sbs in sbs_cols:
            vals = pd.to_numeric(grupo[sbs], errors="coerce").fillna(0)
            row[sbs] = vals.sum() / 100_000
        records.append(row)

    pos = pd.DataFrame(records).set_index("Fecha").sort_index()
    return pos


