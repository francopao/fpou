  user-select: none;
}
.legend-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

/* ── Z-axis reference lines label ── */
.ref-label {
  font-size: 10px;
  color: var(--muted);
  font-family: var(--mono);
}

/* ── Loading ── */
#loading {
  position: fixed; inset: 0;
  background: var(--bg);
  display: flex; align-items: center; justify-content: center;
  z-index: 999;
  font-family: var(--mono);
  font-size: 13px;
  color: var(--muted);
  letter-spacing: 0.08em;
  flex-direction: column;
