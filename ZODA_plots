  <!-- ══════════════════════════════════════════════════
       GRÁFICO 2 — BUBBLE CHART (Monitor)
  ══════════════════════════════════════════════════ -->
  <div class="section">
    <div class="section-header">
      <span class="section-num">02</span>
      <span class="section-title">Monitor de Posición — Burbuja de Valorización</span>
      <span class="section-desc">Tamaño ∝ posición consolidada Fondos 1+2+3 (S/. 100k)</span>
    </div>

    <div class="controls">
      <div class="control-group">
        <span class="control-label">Fecha</span>
        <input type="date" id="sel-fecha-bubble" onchange="onBubbleFecha()">
      </div>
      <div class="control-group">
        <span class="control-label">Eje Y</span>
        <div class="toggle-group">
