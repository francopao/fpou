</div><!-- /main -->

<script>
// ────────────────────────────────────────────────────────────
// DATOS EMBEBIDOS (generados por Python)
// ────────────────────────────────────────────────────────────
const HIST_DATA   = __HIST_DATA__;
const INTERP_DATA = __INTERP_DATA__;
const BUBBLE_DATA = __BUBBLE_DATA__;
const HEAT_DATA   = __HEAT_DATA__;
const LAST_DATE   = "__LAST_DATE__";
const GEN_DATE    = "__GEN_DATE__";

// ────────────────────────────────────────────────────────────
// ESTADO GLOBAL
// ────────────────────────────────────────────────────────────
let currentEmpresa = null;
let currentZType   = 'abs';      // 'abs' | 'basket' | 'bvl'
let currentYAxis   = 'basket';   // 'basket' | 'bvl'
let currentBubbleFecha = null;

const C = {
  bg:      '#0d1117', surface: '#161b22', border: '#21262d',
  text:    '#e6edf3', muted:   '#7d8590', accent: '#2f81f7',
  green:   '#3fb950', red:     '#f85149', yellow: '#d29922',
};

const LAYOUT_BASE = {
  paper_bgcolor: C.surface,
  plot_bgcolor:  C.surface,
  font:  { family: "'IBM Plex Mono', monospace", size: 11, color: C.muted },
  margin: { t: 20, r: 20, b: 40, l: 50 },
  xaxis: { gridcolor: C.border, linecolor: C.border, tickcolor: C.border,
           zeroline: false },
  yaxis: { gridcolor: C.border, linecolor: C.border, tickcolor: C.border,
           zeroline: false },
  hoverlabel: {
    bgcolor: '#1c2128', bordercolor: C.border,
    font: { family: "'IBM Plex Mono', monospace", size: 11, color: C.text }
  },
  showlegend: false,
};

const CONFIG = {
  displayModeBar: true,
  modeBarButtonsToRemove: ['select2d','lasso2d','autoScale2d'],
  displaylogo: false,
  responsive: true,
};

// ────────────────────────────────────────────────────────────
// INIT
// ────────────────────────────────────────────────────────────
window.addEventListener('load', () => {
  document.getElementById('hdr-date').textContent = 'Generado: ' + GEN_DATE;

  populateEmpresaSelector();
  initBubbleFecha();
  renderHeatmap();

  // Render primer empresa por default
  if (HIST_DATA.length > 0) {
    currentEmpresa = HIST_DATA[0].alias;
    document.getElementById('sel-empresa').value = currentEmpresa;
    renderHistorico();
    renderBubble();
  }

  document.getElementById('loading').style.display = 'none';
});

// ────────────────────────────────────────────────────────────
// SELECTOR DE EMPRESA
// ────────────────────────────────────────────────────────────
function populateEmpresaSelector() {
  const sel = document.getElementById('sel-empresa');
  HIST_DATA.forEach(d => {
    const opt = document.createElement('option');
    opt.value = d.alias;
    opt.textContent = `${d.alias}  —  ${d.sector}`;
    sel.appendChild(opt);
  });
}

function onEmpresaChange() {
  currentEmpresa = document.getElementById('sel-empresa').value;
  renderHistorico();
}

function onZType(type) {
  currentZType = type;
  ['abs','basket','bvl'].forEach(t => {
    document.getElementById('btn-z-' + t).classList.toggle('active', t === type);
  });
  renderHistorico();
}

// ────────────────────────────────────────────────────────────
// GRÁFICO 1 — HISTÓRICO
// ────────────────────────────────────────────────────────────
function renderHistorico() {
  const d = HIST_DATA.find(x => x.alias === currentEmpresa);
  if (!d) return;

  let x, y, yLabel;
  if (currentZType === 'basket' && d.x_basket.length > 0) {
    x = d.x_basket; y = d.y_basket; yLabel = 'Z vs Basket';
  } else if (currentZType === 'bvl' && d.x_bvl.length > 0) {
    x = d.x_bvl; y = d.y_bvl; yLabel = 'Z vs BVL (SPBLPGPT)';
  } else {
    x = d.x; y = d.y; yLabel = 'Z Absoluto';
  }

  // Coloring: positive = reddish, negative = greenish
  const lineColor = (d.z_actual ?? 0) > 0 ? C.red : C.green;

  const trace = {
    x, y,
    type: 'scatter', mode: 'lines',
    line: { color: lineColor, width: 1.8 },
    hovertemplate: '%{x}<br><b>Z = %{y:.3f}</b><extra></extra>',
  };

  // Área bajo la curva
  const traceArea = {
    x, y,
    type: 'scatter', mode: 'none',
    fill: 'tozeroy',
    fillcolor: lineColor + '18',
    hoverinfo: 'skip',
    showlegend: false,
  };

  // Líneas de referencia en ±1.5 y ±0.5
  const shapes = [
    { type:'line', x0:x[0], x1:x[x.length-1], y0: 1.5, y1: 1.5,
      line:{color:C.red, width:1, dash:'dot'} },
    { type:'line', x0:x[0], x1:x[x.length-1], y0:-1.5, y1:-1.5,
      line:{color:C.green, width:1, dash:'dot'} },
    { type:'line', x0:x[0], x1:x[x.length-1], y0: 0.5, y1: 0.5,
      line:{color:C.yellow, width:.7, dash:'dot'} },
    { type:'line', x0:x[0], x1:x[x.length-1], y0:-0.5, y1:-0.5,
      line:{color:C.yellow, width:.7, dash:'dot'} },
    { type:'line', x0:x[0], x1:x[x.length-1], y0: 0, y1: 0,
      line:{color:C.muted, width:1} },
  ];

  const annotations = [
    { x:x[x.length-1], y: 1.5, xref:'x', yref:'y', text:'+1.5σ',
      showarrow:false, font:{size:9, color:C.red}, xanchor:'right', yanchor:'bottom' },
    { x:x[x.length-1], y:-1.5, xref:'x', yref:'y', text:'−1.5σ',
      showarrow:false, font:{size:9, color:C.green}, xanchor:'right', yanchor:'top' },
  ];

  const layout = {
    ...LAYOUT_BASE,
    yaxis: { ...LAYOUT_BASE.yaxis, title: { text: yLabel, font:{size:10} } },
    shapes, annotations,
    margin: { t:16, r:20, b:36, l:55 },
  };

  Plotly.react('plot-hist', [traceArea, trace], layout, CONFIG);
  updateInterpretacion(d);
}

// ────────────────────────────────────────────────────────────
// PANEL DE INTERPRETACIÓN
// ────────────────────────────────────────────────────────────
function updateInterpretacion(d) {
  const interp = INTERP_DATA[d.alias];
  if (!interp) return;

  const badge = document.getElementById('interp-badge');
  badge.textContent = interp.señal;
  badge.style.background = interp.color + '22';
  badge.style.color = interp.color;
  badge.style.border = `1px solid ${interp.color}44`;

  document.getElementById('interp-short').textContent = interp.corto;
  document.getElementById('interp-long').textContent  = interp.largo;

  const pct = interp.percentil !== null
    ? ` · Percentil histórico: ${interp.percentil.toFixed(0)}°`
    : '';
  document.getElementById('interp-meta').textContent =
    `Empresa: ${d.empresa} · Sector: ${d.sector}${pct}`;
}

// ────────────────────────────────────────────────────────────
// GRÁFICO 2 — BUBBLE CHART
// ────────────────────────────────────────────────────────────
function initBubbleFecha() {
  const fechas = Object.keys(BUBBLE_DATA).sort();
  currentBubbleFecha = fechas[fechas.length - 1];
  const inp = document.getElementById('sel-fecha-bubble');
  inp.value = currentBubbleFecha;
  inp.min = fechas[0];
  inp.max = fechas[fechas.length - 1];
  buildBubbleLegend();
}

function onBubbleFecha() {
  const inp = document.getElementById('sel-fecha-bubble');
  // Snap to nearest available date
  const fechas = Object.keys(BUBBLE_DATA).sort();
  const sel = inp.value;
  let best = fechas[0];
  for (const f of fechas) { if (f <= sel) best = f; }
  currentBubbleFecha = best;
  renderBubble();
}

function onYAxis(axis) {
  currentYAxis = axis;
  ['basket','bvl'].forEach(a => {
    document.getElementById('btn-y-' + a).classList.toggle('active', a === axis);
  });
  renderBubble();
}

function buildBubbleLegend() {
  const sectores = {};
  Object.values(BUBBLE_DATA).forEach(puntos => {
    puntos.forEach(p => { sectores[p.sector] = p.color; });
  });
  const row = document.getElementById('bubble-legend');
  row.innerHTML = '';
  Object.entries(sectores).forEach(([sec, col]) => {
    row.innerHTML += `
      <div class="legend-item" onclick="toggleSector('${sec}')">
        <div class="legend-dot" style="background:${col}"></div>
        <span>${sec}</span>
      </div>`;
  });
}

const hiddenSectors = new Set();
function toggleSector(sec) {
  if (hiddenSectors.has(sec)) hiddenSectors.delete(sec);
  else hiddenSectors.add(sec);
  renderBubble();
}

function renderBubble() {
  const puntos = (BUBBLE_DATA[currentBubbleFecha] || [])
    .filter(p => !hiddenSectors.has(p.sector));

  if (puntos.length === 0) {
    Plotly.react('plot-bubble', [], { ...LAYOUT_BASE }, CONFIG);
    return;
  }

  const yKey = currentYAxis === 'basket' ? 'z_basket' : 'z_bvl';
  const yLabel = currentYAxis === 'basket' ? 'Z vs Basket' : 'Z vs BVL';

  // Agrupar por sector para tooltips
  const bySector = {};
  puntos.forEach(p => {
    if (!bySector[p.sector]) bySector[p.sector] = [];
    bySector[p.sector].push(p);
  });

  const traces = Object.entries(bySector).map(([sec, pts]) => {
    const valid = pts.filter(p => p[yKey] !== null);
    const sizeScale = 0.06;
    return {
      type: 'scatter', mode: 'markers+text',
      x: valid.map(p => p.z_abs),
      y: valid.map(p => p[yKey]),
      text: valid.map(p => p.alias),
      textposition: 'top center',
      textfont: { size: 9, color: '#e6edf3' },
      marker: {
        size:    valid.map(p => Math.max(8, Math.sqrt(p.size) * sizeScale * 60)),
        color:   valid[0]?.color + 'bb',
        line:    { color: valid[0]?.color, width: 1.2 },
        sizemode: 'diameter',
      },
      hovertemplate:
        '<b>%{text}</b><br>' +
        'Z Abs: %{x:.3f}<br>' +
        yLabel + ': %{y:.3f}<br>' +
        'Posición: ' + valid.map(p => (p.size).toLocaleString('es-PE', {maximumFractionDigits:0})).join('|') +
        ' (S/. 100k)<extra>' + sec + '</extra>',
      name: sec,
    };
  });

  // Cuadrantes de fondo
  const shapes = [
    // Cara-cara (Q1)
    { type:'rect', x0:0, x1:5, y0:0, y1:5,
      fillcolor:'#f8514910', line:{width:0} },
    // Barata-barata (Q3)
    { type:'rect', x0:-5, x1:0, y0:-5, y1:0,
      fillcolor:'#3fb95010', line:{width:0} },
    // Ejes
    { type:'line', x0:-5, x1:5, y0:0, y1:0,
      line:{color:C.muted, width:0.8} },
    { type:'line', x0:0, x1:0, y0:-5, y1:5,
      line:{color:C.muted, width:0.8} },
  ];

  const annotations = [
    { x:3.5, y:3.5, text:'CARA / CARA', showarrow:false,
      font:{size:9, color:C.red+'88'}, xref:'x', yref:'y' },
    { x:-3.5, y:-3.5, text:'BARATA / BARATA', showarrow:false,
      font:{size:9, color:C.green+'88'}, xref:'x', yref:'y' },
    { x:-3.5, y:3.5, text:'BARATA / CARA', showarrow:false,
      font:{size:9, color:C.yellow+'88'}, xref:'x', yref:'y' },
    { x:3.5, y:-3.5, text:'CARA / BARATA', showarrow:false,
      font:{size:9, color:C.yellow+'88'}, xref:'x', yref:'y' },
  ];

  const layout = {
    ...LAYOUT_BASE,
    showlegend: true,
    legend: {
      bgcolor: C.surface, bordercolor: C.border, borderwidth: 1,
      font: { size: 10 }, orientation: 'h', x: 0, y: -0.12,
    },
    xaxis: { ...LAYOUT_BASE.xaxis, title: { text: 'Z Absoluto', font:{size:10} }, zeroline:false },
    yaxis: { ...LAYOUT_BASE.yaxis, title: { text: yLabel, font:{size:10} }, zeroline:false },
    shapes, annotations,
    margin: { t:16, r:20, b:60, l:55 },
    title: {
      text: `Monitor · ${currentBubbleFecha}`,
      font: { size:11, color: C.muted }, x:0.01, xanchor:'left',
    },
  };

  Plotly.react('plot-bubble', traces, layout, CONFIG);
}

// ────────────────────────────────────────────────────────────
// GRÁFICO 3 — HEATMAP
// ────────────────────────────────────────────────────────────
function renderHeatmap() {
  const d = HEAT_DATA;
  if (!d || !d.z || d.z.length === 0) return;

  // Reemplazar null por NaN para Plotly
  const z_clean = d.z.map(row => row.map(v => v === null ? NaN : v));

  // Etiquetas enriquecidas: alias (sector)
  const yLabels = d.y.map((alias, i) => `${alias} · ${d.sectores[i]}`);

  const trace = {
    type: 'heatmap',
    x: d.x,
    y: yLabels,
    z: z_clean,
    colorscale: [
      [0.0,  '#1a7f37'],   // barata profunda
      [0.3,  '#2da44e'],   // barata
      [0.42, '#3fb950'],
      [0.48, '#7d8590'],   // neutro
      [0.52, '#7d8590'],
      [0.58, '#d29922'],
      [0.7,  '#f85149'],   // cara
      [1.0,  '#b91c1c'],   // cara profunda
    ],
    zmid: 0,
    zmin: -2.5,
    zmax:  2.5,
    colorbar: {
      title: { text:'Z', font:{size:10} },
      thickness: 12,
      len: 0.6,
      tickfont: { size:9 },
      bgcolor: C.surface,
      bordercolor: C.border,
    },
    hovertemplate:
      '<b>%{y}</b><br>Semana: %{x}<br><b>Z = %{z:.3f}</b><extra></extra>',
    xgap: 1, ygap: 1,
  };

  const height = Math.max(400, d.y.length * 22 + 60);

  const layout = {
    ...LAYOUT_BASE,
    height,
    margin: { t:16, r:80, b:60, l:130 },
    xaxis: {
      ...LAYOUT_BASE.xaxis,
      type: 'category',
      nticks: 12,
      tickangle: -35,
      tickfont: { size: 9 },
    },
    yaxis: {
      ...LAYOUT_BASE.yaxis,
      tickfont: { size: 9.5 },
      autorange: 'reversed',
    },
  };

  Plotly.react('plot-heat', [trace], layout, CONFIG);
}
</script>
</body>
</html>
"""


def generar_html(bd, param, gics, posiciones, fecha_gen):
    print("  → Construyendo gráfico 1: histórico…")
    hist_traces, interp = build_historico(bd, param, gics)

    print("  → Construyendo gráfico 2: bubble chart…")
    bubble_data = build_bubble_data(bd, param, gics, posiciones)

    print("  → Construyendo gráfico 3: heatmap…")
    heat_data = build_heatmap_data(bd, param, gics)

    # Última fecha con dato en BD
    z_emp_cols = [
        c for c in bd.columns
        if c.startswith("Z_") and "Basket" not in c and "BVL" not in c
        and "MXLA" not in c and "Index" not in c
    ]
    last_valid = bd.loc[bd[z_emp_cols].notna().any(axis=1), "Fecha"].max()
    last_date_str = last_valid.strftime("%Y-%m-%d") if pd.notna(last_valid) else ""

    html = HTML_TEMPLATE
    html = html.replace("__HIST_DATA__",   json.dumps(hist_traces,  ensure_ascii=False))
    html = html.replace("__INTERP_DATA__", json.dumps(interp,       ensure_ascii=False))
    html = html.replace("__BUBBLE_DATA__", json.dumps(bubble_data,  ensure_ascii=False))
    html = html.replace("__HEAT_DATA__",   json.dumps(heat_data,    ensure_ascii=False))
    html = html.replace("__LAST_DATE__",   last_date_str)
    html = html.replace("__GEN_DATE__",    fecha_gen)

    return html


# ──────────────────────────────────────────────────────────────────────────────
# MAIN
# ──────────────────────────────────────────────────────────────────────────────

def main():
    inicio = datetime.datetime.now()
    fecha_gen = inicio.strftime("%d/%m/%Y %H:%M")
    fecha_tag = inicio.strftime("%d.%m.%y")

    print("=" * 60)
    print("  ZODA Dashboard — Generador HTML")
    print(f"  {fecha_gen}")
    print("=" * 60)

    print("\n[1/5] Leyendo BD…")
    bd = cargar_bd()
    print(f"  → {len(bd)} filas | {bd['Fecha'].min().date()} → {bd['Fecha'].max().date()}")

    print("\n[2/5] Leyendo Parametría…")
    param = cargar_parametria()
    print(f"  → {len(param)} activos mapeados")

    print("\n[3/5] Leyendo GICS…")
    gics = cargar_gics()

    print("\n[4/5] Leyendo posiciones DQ_IN…")
    posiciones = cargar_posiciones()
    if not posiciones.empty:
        print(f"  → Posiciones disponibles hasta {posiciones.index.max().date()}")
    else:
        print("  ⚠ DQ_IN sin datos de posición")

    print("\n[5/5] Generando HTML…")
    html = generar_html(bd, param, gics, posiciones, fecha_gen)

    nombre_archivo = f"ZODA_Dashboard_{fecha_tag}.html"
    ruta_html = os.path.join(RUTA_SALIDA, nombre_archivo)

    with open(ruta_html, "w", encoding="utf-8") as f:
        f.write(html)

    tam_mb = os.path.getsize(ruta_html) / 1_048_576
    fin = datetime.datetime.now()

