<body>

<div id="loading">
  <div class="spinner"></div>
  <span>Cargando ZODA Dashboard…</span>
</div>

<div class="header">
  <span class="header-title">ZODA</span>
  <span class="header-sub">Monitor de Valorización · AFP Integra</span>
  <span class="header-date" id="hdr-date"></span>
</div>

<div class="main">

  <!-- ══════════════════════════════════════════════════
       GRÁFICO 1 — SERIE HISTÓRICA
  ══════════════════════════════════════════════════ -->
  <div class="section">
    <div class="section-header">
      <span class="section-num">01</span>
      <span class="section-title">Evolución Histórica del Z-Score</span>
      <span class="section-desc">Z compuesto (1Y·33% + 3Y·33% + 5Y·33%)</span>
    </div>

    <div class="controls">
      <div class="control-group">
        <span class="control-label">Empresa</span>
