# Departamentos sin entrada → "Otros" por defecto
for dep in gdf["NOMBDEP"].unique():
    if dep not in PORTFOLIO:
        PORTFOLIO[dep] = [("Otros", 5, 0.15, 0.25)]

# ── 4. FUNCIONES AUXILIARES ────────────────────────────────────────────────────

def pesos_normalizados(entradas):
    w = np.array([aum * exp * rf for _, aum, exp, rf in entradas], dtype=float)
    return w / w.sum()

def extraer_polygons(geom):
    if geom is None or geom.is_empty:
        return []
    if isinstance(geom, Polygon):
        return [geom] if not geom.is_empty else []
    if isinstance(geom, (MultiPolygon, GeometryCollection)):
        result = []
        for g in geom.geoms:
            result.extend(extraer_polygons(g))
        return result
    return []

def geom_a_patches(geom, **kw):
    patches = []
    for poly in extraer_polygons(geom):
        ext = np.array(poly.exterior.coords)
        codes = [Path.MOVETO] + [Path.LINETO] * (len(ext) - 2) + [Path.CLOSEPOLY]
        verts = list(ext)
        for interior in poly.interiors:
            ic = np.array(interior.coords)
            codes += [Path.MOVETO] + [Path.LINETO] * (len(ic) - 2) + [Path.CLOSEPOLY]
            verts += list(ic)
        patches.append(PathPatch(Path(verts, codes), **kw))
    return patches

def subdividir_vertical(poligono, pesos):
    """Cortes verticales proporcionales a pesos dentro del bounding box."""
    if poligono is None or poligono.is_empty:
        return []
    pesos = np.array(pesos, dtype=float) / np.sum(pesos)
    mn_x, mn_y, mx_x, mx_y = poligono.bounds
    ancho = mx_x - mn_x
    subs, acum = [], 0.0
    eps = 1e-6
    for w in pesos:
        banda = box(mn_x + acum * ancho - eps, mn_y - eps,
                    mn_x + (acum + w) * ancho + eps, mx_y + eps)
        sub = poligono.intersection(banda)
        subs.append(sub)
        acum += w
    return subs

# ── 5. FIGURA ──────────────────────────────────────────────────────────────────

fig, ax = plt.subplots(figsize=(11, 15))
ax.set_aspect("equal")
ax.axis("off")
fig.patch.set_facecolor("#F1F5F9")
ax.set_facecolor("#BFDBFE")  # fondo oceánico

for _, row in gdf.iterrows():
    dep      = row["NOMBDEP"]
    geom     = row["geometry"]
    entradas = PORTFOLIO.get(dep, [("Otros", 5, 0.15, 0.25)])
    pesos    = pesos_normalizados(entradas)

    if len(entradas) == 1:
        color = EMPRESA_COLOR.get(entradas[0][0], "#9CA3AF")
        for p in geom_a_patches(geom, facecolor=color, edgecolor="none", alpha=0.85, zorder=2):
            ax.add_patch(p)
    else:
        subzonas = subdividir_vertical(geom, pesos)
        for idx, (empresa, *_) in enumerate(entradas):
            if idx >= len(subzonas):
                break
            color = EMPRESA_COLOR.get(empresa, "#9CA3AF")
            for p in geom_a_patches(subzonas[idx], facecolor=color, edgecolor="none", alpha=0.85, zorder=2):
                ax.add_patch(p)

    # Borde departamental
    for p in geom_a_patches(geom, facecolor="none", edgecolor="#1E293B", linewidth=0.6, zorder=4):
        ax.add_patch(p)

# ── 6. LEYENDA ─────────────────────────────────────────────────────────────────

leyenda = [
    mpatches.Patch(facecolor=c, edgecolor="#374151", linewidth=0.7, label=e, alpha=0.88)
    for e, c in EMPRESA_COLOR.items()
]
leg = ax.legend(
    handles=leyenda, title="Empresa", title_fontsize=9, fontsize=8.5,
    loc="lower left", frameon=True, framealpha=0.93,
    edgecolor="#CBD5E1", facecolor="white",
)
leg.get_title().set_fontweight("bold")

# ── 7. TÍTULO ──────────────────────────────────────────────────────────────────

ax.set_title(
    "Exposición Geográfica del Portafolio — Perú (24 departamentos)\n"
    r"$\bf{Peso\ subzona}$ = AUM × Exposición × Riesgo Físico",
    fontsize=12, fontweight="bold", color="#0F172A", pad=12,
)
fig.text(
    0.5, 0.005,
    "Subdivisión interna proporcional al peso económico ponderado por riesgo físico",
    ha="center", fontsize=7.5, color="#64748B", style="italic",
)

# Ajuste de vista
minx, miny, maxx, maxy = gdf.total_bounds
