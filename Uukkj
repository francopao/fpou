    urllib.request.urlretrieve(GEOJSON_URL, GEOJSON_PATH)

gdf = gpd.read_file(GEOJSON_PATH)  # columna: NOMBDEP

# ── 2. COLORES FIJOS ───────────────────────────────────────────────────────────

