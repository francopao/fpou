"""
portfolio_peru_map.py
Visualiza exposición geográfica del portafolio por departamento peruano.
Cada departamento se subdivide en subzonas proporcionales a:
    peso = AUM × exposición × riesgo_físico

Dependencias: pip install geopandas matplotlib shapely numpy requests
"""

import os
import urllib.request
import numpy as np
import geopandas as gpd
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
from matplotlib.patches import PathPatch
from matplotlib.path import Path
from shapely.geometry import box, Polygon, MultiPolygon, GeometryCollection

# ── 1. DESCARGA SHAPEFILE ──────────────────────────────────────────────────────

GEOJSON_PATH = "/tmp/peru_dptos.geojson"
