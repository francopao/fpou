# ──────────────────────────────────────────────────────────────────────────────
# GRÁFICO 4 — EQRV PERCENTILE CHART (Bloomberg/JPM style)
# ──────────────────────────────────────────────────────────────────────────────

def build_eqrv_data(bd, param, gics):
    """
    Para cada empresa del portafolio calcula la distribución histórica del Z-score:
    p10, p25, p50, p75, p90 y el valor actual.
    Agrupa por sector para mantener el ordenamiento visual.
    Inspirado en el EQRV de Bloomberg y el gráfico de percentiles de J.P. Morgan AM.
    Ref: JPM Asset Management — Guide to the Markets (Q1 2026).
    """
    results = []
    for _, r in param.iterrows():
        alias  = r["alias"]
        z_col  = r["z_col"]
        bbg    = r["bbg_ticker"]
        if z_col not in bd.columns or z_col.startswith("nan"):
            continue
        if "Index" in z_col:
            continue

        serie = bd[z_col].dropna()
        if len(serie) < 52:
            continue

        sector = gics.loc[bbg, "GICS"] if bbg in gics.index else "Other"
        nombre = gics.loc[bbg, "Empresa"] if bbg in gics.index else alias
        current = float(serie.iloc[-1])
        pct_rank = float((serie < current).mean() * 100)

        results.append(dict(
            alias=alias,
            empresa=nombre,
            sector=sector,
            color=SECTOR_COLOR.get(sector, C["muted"]),
            current=round(current, 3),
            p10=round(float(serie.quantile(0.10)), 3),
            p25=round(float(serie.quantile(0.25)), 3),
            p50=round(float(serie.quantile(0.50)), 3),
            p75=round(float(serie.quantile(0.75)), 3),
            p90=round(float(serie.quantile(0.90)), 3),
            pct_rank=round(pct_rank, 1),
            n_obs=int(len(serie)),
        ))

    # Sort: by sector then by current Z descending
    sector_order = ["Financials", "Consumer", "Construction Materials",
                    "Industrials", "Health Care", "Media",
                    "Mining", "Utilities", "Other"]
    results.sort(key=lambda x: (
        sector_order.index(x["sector"]) if x["sector"] in sector_order else 99,
        -x["current"]
    ))
    return results

def generar_html(bd, param, gics, posiciones, fecha_gen):
    # Cargar logo AFP Integra en base64 (si existe en la ruta configurada)
    logo_b64 = ""
    try:
        if os.path.exists(RUTA_LOGO):
            with open(RUTA_LOGO, "rb") as _f:
                logo_b64 = "data:image/png;base64," + base64.b64encode(_f.read()).decode()
    except Exception:
        pass

    print("  → Construyendo gráfico 1: histórico…")
    hist_traces, interp = build_historico(bd, param, gics)

    print("  → Construyendo gráfico 2: bubble chart…")
    bubble_data = build_bubble_data(bd, param, gics, posiciones)

    print("  → Construyendo gráfico 3: heatmap…")
    heat_data = build_heatmap_data(bd, param, gics)

    print("  → Construyendo gráfico 4: EQRV percentiles…")
    eqrv_data = build_eqrv_data(bd, param, gics)

    # Última fecha con dato en BD
    z_emp_cols = [
        c for c in bd.columns
        if c.startswith("Z_") and "Basket" not in c and "BVL" not in c
        and "MXLA" not in c and "Index" not in c
    ]
    last_valid = bd.loc[bd[z_emp_cols].notna().any(axis=1), "Fecha"].max()
    last_date_str = last_valid.strftime("%Y-%m-%d") if pd.notna(last_valid) else ""

    html = HTML_TEMPLATE
    html = html.replace("__HIST_DATA__",   json.dumps(hist_traces,  ensure_ascii=False))
    html = html.replace("__INTERP_DATA__", json.dumps(interp,       ensure_ascii=False))
    html = html.replace("__BUBBLE_DATA__", json.dumps(bubble_data,  ensure_ascii=False))
    html = html.replace("__HEAT_DATA__",   json.dumps(heat_data,    ensure_ascii=False))
    html = html.replace("__EQRV_DATA__",   json.dumps(eqrv_data,   ensure_ascii=False))
    html = html.replace("__LOGO_B64__",    logo_b64)
    html = html.replace("__LAST_DATE__",   last_date_str)
    html = html.replace("__GEN_DATE__",    fecha_gen)

    return html


