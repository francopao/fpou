# GRÁFICO 1 — SERIE HISTÓRICA DE Z-SCORE
# ──────────────────────────────────────────────────────────────────────────────

def build_historico(bd, param, gics):
    """
    Retorna lista de trazas y datos JSON para el gráfico histórico interactivo.
    Un trace por empresa; solo uno visible a la vez (controlado por JS).
    """
    empresas_bd = [
        r for _, r in param.iterrows()
        if str(r["z_col"]) in bd.columns and not str(r["z_col"]).startswith("nan")
    ]

    traces = []
    interpretaciones = {}

    for r in empresas_bd:
        alias   = r["alias"]
        z_col   = r["z_col"]
        bk_col  = r["basket_col"] if r["basket_col"] in bd.columns else None
        bvl_col = r["bvl_col"]    if r["bvl_col"]    in bd.columns else None
        bbg     = r["bbg_ticker"]
        sector  = gics.loc[bbg, "GICS"] if bbg in gics.index else "Index"
        empresa_nombre = gics.loc[bbg, "Empresa"] if bbg in gics.index else alias
        color   = SECTOR_COLOR.get(sector, C["muted"])

        serie = bd[["Fecha", z_col]].dropna(subset=[z_col]).copy()
        if serie.empty:
            continue

        # Z actual (última fecha con dato)
        z_actual = serie[z_col].iloc[-1]
        # Percentil histórico del Z actual
        pct = (serie[z_col] < z_actual).mean() * 100

        # Trace principal Z
        traces.append(dict(
            alias=alias,
            x=serie["Fecha"].dt.strftime("%Y-%m-%d").tolist(),
            y=serie[z_col].round(4).tolist(),
            y_basket=bd[["Fecha", bk_col]].dropna(subset=[bk_col])[bk_col].round(4).tolist()
                     if bk_col else [],
            x_basket=bd[["Fecha", bk_col]].dropna(subset=[bk_col])["Fecha"]
                     .dt.strftime("%Y-%m-%d").tolist() if bk_col else [],
            y_bvl=bd[["Fecha", bvl_col]].dropna(subset=[bvl_col])[bvl_col].round(4).tolist()
                  if bvl_col else [],
            x_bvl=bd[["Fecha", bvl_col]].dropna(subset=[bvl_col])["Fecha"]
                  .dt.strftime("%Y-%m-%d").tolist() if bvl_col else [],
            color=color,
            sector=sector,
            empresa=empresa_nombre,
            z_actual=round(z_actual, 4) if not np.isnan(z_actual) else None,
            percentil=round(pct, 1),
        ))

        señal, sig_color, txt_corto, txt_largo = interpretar_z(z_actual, pct, empresa_nombre)
        interpretaciones[alias] = dict(
            señal=señal, color=sig_color,
            corto=txt_corto, largo=txt_largo,
            z_actual=round(z_actual, 4) if not np.isnan(z_actual) else None,
            percentil=round(pct, 1),
        )

    return traces, interpretaciones


