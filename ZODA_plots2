.interp-short { font-size: 12px; font-weight: 600; margin-bottom: 6px; }
.interp-long  { font-size: 11px; color: var(--muted); line-height: 1.65; }
.interp-meta  { font-family: var(--mono); font-size: 10px; color: var(--muted); margin-top: 8px; }

/* ── Footnote ── */
.footnote {
  font-size: 9px; color: var(--muted); letter-spacing: 0.02em;
  margin-top: 10px; padding-left: 8px;
  border-left: 2px solid var(--brand-teal); line-height: 1.7;
}
.footnote em { color: rgba(255,255,255,0.4); }

/* ── Legend ── */
.legend-row { display: flex; flex-wrap: wrap; gap: 14px; margin-bottom: 12px; }
.legend-item {
  display: flex; align-items: center; gap: 6px;
  font-size: 10px; color: var(--muted); cursor: pointer; user-select: none;
}
.legend-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

/* ── Footer ── */
.footer {
  border-top: 1px solid var(--border);
  padding: 16px 32px;
  display: flex; align-items: center; gap: 12px;
  margin-top: 32px;
}
.footer-brand {
  font-family: var(--mono); font-size: 9px;
  color: var(--brand-teal); letter-spacing: 0.1em; text-transform: uppercase;
}
.footer-disclaimer {
  font-size: 9px; color: var(--muted); line-height: 1.5; flex: 1;
}
.footer-author {
  font-size: 9px; color: rgba(255,255,255,0.18);
  font-style: italic; font-family: var(--sans);
  letter-spacing: 0.02em;
}

/* ── Loading ── */
#loading {
  position: fixed; inset: 0; background: var(--bg);
  display: flex; align-items: center; justify-content: center;
  z-index: 999; font-family: var(--mono); font-size: 13px;
  color: var(--muted); letter-spacing: 0.08em;
  flex-direction: column; gap: 16px;
}
.spinner {
  width: 28px; height: 28px;
  border: 2px solid var(--border);
  border-top-color: var(--brand-teal);
  border-radius: 50%;
  animation: spin .7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
</style>
</head>
<body>

<div id="loading">
  <div class="spinner"></div>
  <span>Cargando ZODA Dashboard…</span>
</div>

<!-- ════════════════════ HEADER ════════════════════ -->
<div class="header">
  <img id="logo-img" class="header-logo" src="__LOGO_B64__" alt="AFP Integra"
       onerror="this.style.display='none';document.getElementById('logo-ph').style.display='flex'">
  <div id="logo-ph" class="header-logo-placeholder" style="display:none">AFP INTEGRA</div>
  <div class="header-divider"></div>
  <div>
    <div class="header-title">ZODA</div>
    <div class="header-sub">Monitor de Valorización · Renta Variable</div>
  </div>
  <div class="header-spacer"></div>
  <div class="header-meta">
    <div class="header-date" id="hdr-date"></div>
    <div class="header-author">Franco Olivares</div>
  </div>
</div>

<div class="main">

  <!-- ══ 01 HISTÓRICO ══ -->
  <div class="section">
    <div class="section-header">
      <span class="section-num">01</span>
      <span class="section-title">Evolución Histórica del Z-Score</span>
      <span class="section-desc">Z compuesto · 1Y × 33% + 3Y × 33% + 5Y × 33%</span>
    </div>
    <div class="controls">
      <div class="control-group">
        <span class="control-label">Empresa</span>
        <select id="sel-empresa" onchange="onEmpresaChange()"></select>
      </div>
      <div class="control-group">
        <span class="control-label">Tipo de Z</span>
        <div class="toggle-group">
          <button class="toggle-btn active" id="btn-z-abs"    onclick="onZType('abs')">Absoluto</button>
          <button class="toggle-btn"        id="btn-z-basket" onclick="onZType('basket')">vs Basket</button>
          <button class="toggle-btn"        id="btn-z-bvl"    onclick="onZType('bvl')">vs BVL</button>
        </div>
      </div>
    </div>
    <div class="plot-wrap"><div id="plot-hist" style="height:360px;"></div></div>
    <div class="interp-panel" id="interp-panel">
      <span class="interp-badge" id="interp-badge">—</span>
      <div>
        <div class="interp-short" id="interp-short">Selecciona una empresa</div>
        <div class="interp-long"  id="interp-long"></div>
        <div class="interp-meta"  id="interp-meta"></div>
      </div>
    </div>
  </div>

  <!-- ══ 02 BUBBLE CHART ══ -->
  <div class="section">
    <div class="section-header">
      <span class="section-num">02</span>
      <span class="section-title">Monitor de Posición — Mapa de Valorización</span>
      <span class="section-desc">Tamaño de burbuja ∝ posición consolidada Fondos 1+2+3 (S/. 100k)</span>
    </div>
    <div class="controls">
      <div class="control-group">
        <span class="control-label">Fecha</span>
        <input type="date" id="sel-fecha-bubble" onchange="onBubbleFecha()">
      </div>
      <div class="control-group">
        <span class="control-label">Eje Y</span>
        <div class="toggle-group">
          <button class="toggle-btn active" id="btn-y-basket" onclick="onYAxis('basket')">vs Basket</button>
          <button class="toggle-btn"        id="btn-y-bvl"    onclick="onYAxis('bvl')">vs BVL</button>
        </div>
      </div>
    </div>
    <div class="legend-row" id="bubble-legend"></div>
    <div class="plot-wrap"><div id="plot-bubble" style="height:520px;"></div></div>
  </div>

  <!-- ══ 03 HEATMAP ══ -->
  <div class="section">
    <div class="section-header">
      <span class="section-num">03</span>
      <span class="section-title">Régimen de Valorización — Mapa de Calor 12 meses</span>
      <span class="section-desc">Frecuencia semanal · Verde = barata · Rojo = cara</span>
    </div>
    <div class="plot-wrap"><div id="plot-heat" style="min-height:480px;"></div></div>
    <p class="footnote">
      ¹ Inspirado en el factor exposure dashboard de BlackRock Investment Institute.
      Ref.: Asness, C., Moskowitz, T. &amp; Pedersen, L. (2013). <em>Value and Momentum Everywhere.</em>
      <em>Journal of Finance</em>, 68(3), 929–985. Señales de valor sostenidas ≥ 3 meses
      (Z &lt; −1.5) presentan estadísticamente mayor probabilidad de reversión hacia la media histórica.
    </p>
  </div>

  <!-- ══ 04 EQRV PERCENTILE CHART ══ -->
  <div class="section">
    <div class="section-header">
      <span class="section-num">04</span>
      <span class="section-title">Distribución Histórica del Z-Score — Estilo EQRV</span>
      <span class="section-desc">Valor actual vs percentiles históricos · Agrupado por sector</span>
    </div>
    <div class="controls">
      <div class="control-group">
        <span class="control-label">Ordenar por</span>
        <div class="toggle-group">
          <button class="toggle-btn active" id="btn-sort-sec"  onclick="onEqrvSort('sector')">Sector</button>
          <button class="toggle-btn"        id="btn-sort-z"    onclick="onEqrvSort('z')">Z actual ↓</button>
          <button class="toggle-btn"        id="btn-sort-pct"  onclick="onEqrvSort('pct')">Percentil ↓</button>
        </div>
      </div>
    </div>
    <div class="plot-wrap"><div id="plot-eqrv" style="height:520px;"></div></div>
    <p class="footnote">
      ² Inspirado en el <em>Equity Relative Valuation</em> (EQRV) de Bloomberg Terminal
      y en los gráficos de percentil de PE Forward de J.P. Morgan Asset Management —
      <em>Guide to the Markets</em> (Q1 2026). Muestra dónde se sitúa el Z actual respecto
      a su propia distribución histórica: banda p10–p90 (rango amplio), caja p25–p75 (rango intercuartil),
      mediana (línea punteada) y valor actual (diamante). Un Z en el extremo superior del rango p10–p90
      indica compresión de múltiplo estadísticamente elevada.
    </p>
  </div>

</div><!-- /main -->

<!-- ════════════════════ FOOTER ════════════════════ -->
<div class="footer">
  <span class="footer-brand">AFP Integra · ZODA</span>
  <span class="footer-disclaimer">
    Uso interno exclusivo. Información elaborada a partir de datos de Bloomberg y Capital IQ.
    No constituye asesoramiento de inversión. Los Z-scores son indicadores cuantitativos
    sujetos a revisión por el equipo de inversiones.
  </span>
  <span class="footer-author">Franco Olivares</span>
</div>

<script>
// ── Datos embebidos ──────────────────────────────────────────────────────────
const HIST_DATA   = __HIST_DATA__;
const INTERP_DATA = __INTERP_DATA__;
const BUBBLE_DATA = __BUBBLE_DATA__;
const HEAT_DATA   = __HEAT_DATA__;
const EQRV_DATA   = __EQRV_DATA__;
const LAST_DATE   = "__LAST_DATE__";
const GEN_DATE    = "__GEN_DATE__";

// ── Estado global ────────────────────────────────────────────────────────────
let currentEmpresa    = null;
let currentZType      = 'abs';
let currentYAxis      = 'basket';
let currentBubbleFecha = null;
let eqrvSortMode      = 'sector';

// ── Paleta AFP Integra ───────────────────────────────────────────────────────
const C = {
  bg:'#07101f', surface:'#0d1a2e', surface2:'#111f38', border:'#1a2f50',
  text:'#ddeeff', muted:'#6a85a8',
  navy:'#0033A0', teal:'#00AEC7',
  green:'#29d68b', red:'#f24b4b', yellow:'#e0a720',
};

const LAYOUT_BASE = {
  paper_bgcolor: C.surface,
  plot_bgcolor:  C.surface,
  font:  { family:"'IBM Plex Mono', monospace", size:11, color:C.muted },
  margin: { t:20, r:20, b:40, l:55 },
  xaxis: { gridcolor:C.border, linecolor:C.border, tickcolor:C.border, zeroline:false },
  yaxis: { gridcolor:C.border, linecolor:C.border, tickcolor:C.border, zeroline:false },
  hoverlabel: {
    bgcolor:'#0d1a2e', bordercolor:C.border,
    font:{ family:"'IBM Plex Mono', monospace", size:11, color:C.text }
  },
  showlegend: false,
};

const CONFIG = {
  displayModeBar:true,
  modeBarButtonsToRemove:['select2d','lasso2d','autoScale2d'],
  displaylogo:false, responsive:true,
};

// ── Init ─────────────────────────────────────────────────────────────────────
window.addEventListener('load', () => {
  document.getElementById('hdr-date').textContent = 'Actualizado: ' + GEN_DATE;
  // Hide logo if no b64 data
  const logo = document.getElementById('logo-img');
  if (!logo.src || logo.src === 'data:image/png;base64,') {
    logo.style.display = 'none';
    document.getElementById('logo-ph').style.display = 'flex';
  }

  populateEmpresaSelector();
  initBubbleFecha();
  renderHeatmap();
  renderEqrv();

  if (HIST_DATA.length > 0) {
    currentEmpresa = HIST_DATA[0].alias;
    document.getElementById('sel-empresa').value = currentEmpresa;
    renderHistorico();
    renderBubble();
  }
  document.getElementById('loading').style.display = 'none';
});

// ── Selector empresa ─────────────────────────────────────────────────────────
function populateEmpresaSelector() {
  const sel = document.getElementById('sel-empresa');
  HIST_DATA.forEach(d => {
    const opt = document.createElement('option');
    opt.value = d.alias;
    opt.textContent = `${d.alias}  —  ${d.sector}`;
    sel.appendChild(opt);
  });
}
function onEmpresaChange() {
  currentEmpresa = document.getElementById('sel-empresa').value;
  renderHistorico();
}
function onZType(t) {
  currentZType = t;
  ['abs','basket','bvl'].forEach(x =>
    document.getElementById('btn-z-'+x).classList.toggle('active', x===t));
  renderHistorico();
}

// ── GRÁFICO 1 — HISTÓRICO ────────────────────────────────────────────────────
function renderHistorico() {
  const d = HIST_DATA.find(x => x.alias === currentEmpresa);
  if (!d) return;

  let x, y, yLabel;
  if (currentZType==='basket' && d.x_basket.length>0) {
    x=d.x_basket; y=d.y_basket; yLabel='Z vs Basket';
  } else if (currentZType==='bvl' && d.x_bvl.length>0) {
    x=d.x_bvl; y=d.y_bvl; yLabel='Z vs BVL (SPBLPGPT)';
  } else {
    x=d.x; y=d.y; yLabel='Z Absoluto';
  }

  const lineColor = (d.z_actual||0) > 0 ? C.red : C.green;

  const traceArea = {
    x, y, type:'scatter', mode:'none',
    fill:'tozeroy', fillcolor:lineColor+'18', hoverinfo:'skip',
  };
  const trace = {
    x, y, type:'scatter', mode:'lines',
    line:{color:lineColor, width:1.8},
    hovertemplate:'%{x}<br><b>Z = %{y:.3f}</b><extra></extra>',
  };

  const shapes = [
    {type:'line',x0:x[0],x1:x[x.length-1],y0:1.5,y1:1.5,line:{color:C.red,width:1,dash:'dot'}},
    {type:'line',x0:x[0],x1:x[x.length-1],y0:-1.5,y1:-1.5,line:{color:C.green,width:1,dash:'dot'}},
    {type:'line',x0:x[0],x1:x[x.length-1],y0:.5,y1:.5,line:{color:C.yellow,width:.7,dash:'dot'}},
    {type:'line',x0:x[0],x1:x[x.length-1],y0:-.5,y1:-.5,line:{color:C.yellow,width:.7,dash:'dot'}},
    {type:'line',x0:x[0],x1:x[x.length-1],y0:0,y1:0,line:{color:C.muted,width:1}},
  ];
  const annotations = [
    {x:x[x.length-1],y:1.5,text:'+1.5σ',showarrow:false,font:{size:9,color:C.red},xanchor:'right',yanchor:'bottom'},
    {x:x[x.length-1],y:-1.5,text:'−1.5σ',showarrow:false,font:{size:9,color:C.green},xanchor:'right',yanchor:'top'},
  ];

  Plotly.react('plot-hist', [traceArea,trace], {
    ...LAYOUT_BASE, shapes, annotations,
    yaxis:{...LAYOUT_BASE.yaxis, title:{text:yLabel,font:{size:10}}},
    margin:{t:16,r:20,b:36,l:55},
  }, CONFIG);

  updateInterpretacion(d);
}

function updateInterpretacion(d) {
  const interp = INTERP_DATA[d.alias];
  if (!interp) return;
  const badge = document.getElementById('interp-badge');
  badge.textContent = interp.señal;
  badge.style.background = interp.color+'22';
  badge.style.color = interp.color;
  badge.style.border = `1px solid ${interp.color}44`;
  document.getElementById('interp-short').textContent = interp.corto;
  document.getElementById('interp-long').textContent  = interp.largo;
  const pct = interp.percentil!=null ? ` · Percentil histórico: ${interp.percentil.toFixed(0)}°` : '';
  document.getElementById('interp-meta').textContent =
    `${d.empresa} · ${d.sector}${pct}`;
}

// ── GRÁFICO 2 — BUBBLE CHART ─────────────────────────────────────────────────
function initBubbleFecha() {
  const fechas = Object.keys(BUBBLE_DATA).sort();
  currentBubbleFecha = fechas[fechas.length-1];
  const inp = document.getElementById('sel-fecha-bubble');
  inp.value = currentBubbleFecha;
  inp.min = fechas[0]; inp.max = fechas[fechas.length-1];
  buildBubbleLegend();
}
function onBubbleFecha() {
  const inp = document.getElementById('sel-fecha-bubble');
  const fechas = Object.keys(BUBBLE_DATA).sort();
  let best = fechas[0];
  for (const f of fechas) { if (f <= inp.value) best = f; }
  currentBubbleFecha = best;
  renderBubble();
}
function onYAxis(a) {
  currentYAxis = a;
  ['basket','bvl'].forEach(x =>
    document.getElementById('btn-y-'+x).classList.toggle('active',x===a));
  renderBubble();
}
const hiddenSectors = new Set();
function buildBubbleLegend() {
  const sectores = {};
  Object.values(BUBBLE_DATA).forEach(pts => pts.forEach(p => { sectores[p.sector]=p.color; }));
  const row = document.getElementById('bubble-legend');
  row.innerHTML='';
  Object.entries(sectores).forEach(([sec,col]) => {
    row.innerHTML+=`<div class="legend-item" onclick="toggleSector('${sec}')">
      <div class="legend-dot" style="background:${col}"></div><span>${sec}</span></div>`;
  });
}
function toggleSector(sec) {
  hiddenSectors.has(sec)?hiddenSectors.delete(sec):hiddenSectors.add(sec);
  renderBubble();
}
function renderBubble() {
  const puntos = (BUBBLE_DATA[currentBubbleFecha]||[]).filter(p=>!hiddenSectors.has(p.sector));
  if (!puntos.length) { Plotly.react('plot-bubble',[],{...LAYOUT_BASE},CONFIG); return; }

  const yKey   = currentYAxis==='basket'?'z_basket':'z_bvl';
  const yLabel = currentYAxis==='basket'?'Z vs Basket':'Z vs BVL';

  const bySector={};
  puntos.forEach(p=>{ if(!bySector[p.sector]) bySector[p.sector]=[]; bySector[p.sector].push(p); });

  const traces = Object.entries(bySector).map(([sec,pts]) => {
    const valid=pts.filter(p=>p[yKey]!==null);
    return {
      type:'scatter', mode:'markers+text',
      x:valid.map(p=>p.z_abs), y:valid.map(p=>p[yKey]),
      text:valid.map(p=>p.alias), textposition:'top center',
      textfont:{size:9,color:'#ddeeff'},
      marker:{
        size:valid.map(p=>Math.max(8,Math.sqrt(p.size)*0.06*60)),
        color:valid[0]?.color+'bb', line:{color:valid[0]?.color,width:1.2},
        sizemode:'diameter',
      },
      hovertemplate:'<b>%{text}</b><br>Z Abs: %{x:.3f}<br>'+yLabel+': %{y:.3f}<extra>'+sec+'</extra>',
      name:sec,
    };
  });

  const shapes=[
    {type:'rect',x0:0,x1:6,y0:0,y1:6,fillcolor:C.red+'0e',line:{width:0}},
    {type:'rect',x0:-6,x1:0,y0:-6,y1:0,fillcolor:C.green+'0e',line:{width:0}},
    {type:'line',x0:-6,x1:6,y0:0,y1:0,line:{color:C.muted,width:.8}},
    {type:'line',x0:0,x1:0,y0:-6,y1:6,line:{color:C.muted,width:.8}},
    // AFP Integra brand accent lines
    {type:'line',x0:-6,x1:6,y0:1.5,y1:1.5,line:{color:C.red,width:.6,dash:'dot'}},
    {type:'line',x0:-6,x1:6,y0:-1.5,y1:-1.5,line:{color:C.green,width:.6,dash:'dot'}},
    {type:'line',x0:1.5,x1:1.5,y0:-6,y1:6,line:{color:C.red,width:.6,dash:'dot'}},
    {type:'line',x0:-1.5,x1:-1.5,y0:-6,y1:6,line:{color:C.green,width:.6,dash:'dot'}},
  ];
  const annotations=[
    {x:4,y:4,text:'CARA / CARA',showarrow:false,font:{size:9,color:C.red+'99'},xref:'x',yref:'y'},
    {x:-4,y:-4,text:'BARATA / BARATA',showarrow:false,font:{size:9,color:C.green+'99'},xref:'x',yref:'y'},
    {x:-4,y:4,text:'BARATA / CARA',showarrow:false,font:{size:9,color:C.yellow+'99'},xref:'x',yref:'y'},
    {x:4,y:-4,text:'CARA / BARATA',showarrow:false,font:{size:9,color:C.yellow+'99'},xref:'x',yref:'y'},
  ];

  Plotly.react('plot-bubble', traces, {
    ...LAYOUT_BASE, showlegend:true, shapes, annotations,
    legend:{bgcolor:C.surface,bordercolor:C.border,borderwidth:1,font:{size:10},orientation:'h',x:0,y:-0.12},
    xaxis:{...LAYOUT_BASE.xaxis,title:{text:'Z Absoluto',font:{size:10}},zeroline:false},
    yaxis:{...LAYOUT_BASE.yaxis,title:{text:yLabel,font:{size:10}},zeroline:false},
    margin:{t:16,r:20,b:60,l:55},
    title:{text:`Monitor · ${currentBubbleFecha}`,font:{size:11,color:C.muted},x:.01,xanchor:'left'},
  }, CONFIG);
}

// ── GRÁFICO 3 — HEATMAP ──────────────────────────────────────────────────────
function renderHeatmap() {
  const d = HEAT_DATA;
  if (!d||!d.z||!d.z.length) return;
  const z_clean = d.z.map(row=>row.map(v=>v===null?NaN:v));
  const yLabels = d.y.map((a,i)=>`${a} · ${d.sectores[i]}`);

  const trace = {
    type:'heatmap', x:d.x, y:yLabels, z:z_clean,
    colorscale:[
      [0,'#166534'],[.3,C.green],[.45,'#3a5f4a'],
      [.48,C.muted],[.52,C.muted],
      [.55,'#7a2e2e'],[.7,C.red],[1,'#7f1d1d'],
    ],
    zmid:0, zmin:-2.5, zmax:2.5,
    colorbar:{
      title:{text:'Z',font:{size:10}},
      thickness:10, len:.65, tickfont:{size:9},
      bgcolor:C.surface, bordercolor:C.border,
      tickvals:[-2,-1,0,1,2],
      ticktext:['−2','−1','0','+1','+2'],
    },
    hovertemplate:'<b>%{y}</b><br>Semana: %{x}<br><b>Z = %{z:.3f}</b><extra></extra>',
    xgap:1, ygap:1,
  };

  Plotly.react('plot-heat',[trace],{
    ...LAYOUT_BASE,
    height:Math.max(420,d.y.length*22+70),
    margin:{t:16,r:90,b:60,l:140},
    xaxis:{...LAYOUT_BASE.xaxis,type:'category',nticks:12,tickangle:-35,tickfont:{size:9}},
    yaxis:{...LAYOUT_BASE.yaxis,tickfont:{size:9.5},autorange:'reversed'},
  },CONFIG);
}

// ── GRÁFICO 4 — EQRV PERCENTILE ──────────────────────────────────────────────
function onEqrvSort(mode) {
  eqrvSortMode = mode;
  ['sec','z','pct'].forEach(m =>
    document.getElementById('btn-sort-'+m).classList.toggle('active', m==={sector:'sec',z:'z',pct:'pct'}[mode]));
  renderEqrv();
}

function renderEqrv() {
  if (!EQRV_DATA||!EQRV_DATA.length) return;

  // Sort
  let data = [...EQRV_DATA];
  const SECTOR_ORDER = ['Financials','Consumer','Construction Materials',
                        'Industrials','Health Care','Media','Mining','Utilities','Other'];
  if (eqrvSortMode==='z') {
    data.sort((a,b)=>b.current-a.current);
  } else if (eqrvSortMode==='pct') {
    data.sort((a,b)=>b.pct_rank-a.pct_rank);
  } else {
    data.sort((a,b)=>{
      const si=SECTOR_ORDER.indexOf(a.sector), sj=SECTOR_ORDER.indexOf(b.sector);
      if(si!==sj) return (si<0?99:si)-(sj<0?99:sj);
      return b.current-a.current;
    });
