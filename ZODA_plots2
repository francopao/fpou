# INTERPRETACIÓN AUTOMÁTICA DEL Z-SCORE
# ──────────────────────────────────────────────────────────────────────────────

def interpretar_z(z_val, percentil, empresa):
    """
    Devuelve (señal, color, texto_corto, texto_largo) según el Z y su percentil.
    Lógica: Asness et al. (2013) — value signal es más confiable cuando
    el Z es extremo Y el percentil histórico lo confirma.
    """
    if z_val is None or np.isnan(z_val):
        return "Sin dato", C["muted"], "Sin dato suficiente", (
            "No hay historia suficiente para calcular el Z-score en este período."
        )

    pct_txt = f"percentil {percentil:.0f}" if percentil is not None else ""

    if z_val > 1.5:
        return (
            "CARA",
            C["red"],
            f"Z = {z_val:+.2f} — Valorización elevada ({pct_txt})",
            (
                f"{empresa} cotiza con una prima histórica significativa. "
                f"El múltiplo actual está {z_val:.1f} desviaciones estándar por "
                f"encima de su media. Históricamente, lecturas en este rango han "
                f"precedido compresiones de múltiplo. Revisar si existe catalizador "
                f"justificado (M&A, guidance revision, momentum sectorial)."
            ),
        )
    elif z_val > 0.5:
        return (
            "MODERADAMENTE CARA",
            C["yellow"],
            f"Z = {z_val:+.2f} — Leve presión alcista de múltiplo ({pct_txt})",
            (
                f"{empresa} muestra un múltiplo por encima de su media histórica, "
                f"aunque dentro de rangos manejables. La señal no es de venta, "
                f"pero reduce el margen de seguridad. Monitorear si el avance "
                f"responde a momentum de precio o a revisión real de fundamentales."
            ),
        )
    elif z_val > -0.5:
        return (
            "NEUTRAL",
            C["muted"],
            f"Z = {z_val:+.2f} — Dentro de rango histórico normal ({pct_txt})",
            (
                f"{empresa} cotiza en zona de valorización neutra. "
                f"No hay señal direccional clara desde el múltiplo. "
                f"El diferencial frente a pares (Z Basket) y frente al mercado "
                f"local (Z BVL) son más informativos en este rango."
            ),
        )
    elif z_val > -1.5:
        return (
            "MODERADAMENTE BARATA",
            C["accent"],
            f"Z = {z_val:+.2f} — Descuento moderado ({pct_txt})",
            (
                f"{empresa} cotiza con un descuento respecto a su historia. "
                f"La señal de valor está presente pero aún no en zona extrema. "
                f"Validar con Z Basket: si ambos son negativos, la señal es más "
                f"robusta. Lakonishok et al. (1994) muestran que retornos superiores "
                f"se concentran en acciones con múltiplos persistentemente bajos."
            ),
        )
    else:
        return (
            "BARATA",
            C["green"],
            f"Z = {z_val:+.2f} — Descuento histórico significativo ({pct_txt})",
            (
                f"{empresa} está en zona de descuento histórico profundo. "
                f"Según Asness, Moskowitz & Pedersen (2013), señales de valor "
                f"con Z < −1.5 sostenidas más de 3 meses tienen alta probabilidad "
                f"de reversión. Verificar que el descuento no esté justificado por "
                f"deterioro estructural de fundamentales antes de actuar."
            ),
        )


