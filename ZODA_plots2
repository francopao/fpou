# GRÁFICO 2 — BUBBLE CHART (Monitor)
# ──────────────────────────────────────────────────────────────────────────────

def build_bubble_data(bd, param, gics, posiciones):
    """
    Retorna datos JSON para el bubble chart por fecha.
    Para cada fecha disponible en BD: X=Z_empresa, Y=Z_Basket o Z_BVL,
    size=posición en PEN (S/. 100k), color=sector.
    """
    # Fechas válidas en BD (con algún Z no-NaN)
    z_emp_cols = [
        c for c in bd.columns
        if c.startswith("Z_") and "Basket" not in c and "BVL" not in c
        and "MXLA" not in c and "Index" not in c
    ]
    fechas_bd = bd.loc[bd[z_emp_cols].notna().any(axis=1), "Fecha"]
    fechas_bd = fechas_bd.dt.normalize().unique()

    # Última fecha de posiciones disponible
    if not posiciones.empty:
        last_pos_date = posiciones.index.max()
    else:
        last_pos_date = None

    empresas = [
        r for _, r in param.iterrows()
        if str(r["z_col"]) in bd.columns and not str(r["z_col"]).startswith("nan")
    ]

    # Construir datos por fecha (solo las últimas 400 para no saturar el HTML)
    fechas_sample = sorted(fechas_bd)[-400:]

    bubble_by_date = {}
    for fecha in fechas_sample:
        fkey = fecha.strftime("%Y-%m-%d")
        row_bd = bd[bd["Fecha"].dt.normalize() == fecha]
        if row_bd.empty:
            continue
        row_bd = row_bd.iloc[-1]

        # Posición: usar la fecha más cercana disponible en DQ_IN
        if last_pos_date is not None:
            pos_fecha = posiciones.index[posiciones.index <= fecha]
            if len(pos_fecha) == 0:
                pos_row = None
            else:
                pos_row = posiciones.loc[pos_fecha[-1]]
        else:
            pos_row = None

        puntos = []
        for r in empresas:
            alias   = r["alias"]
            z_col   = r["z_col"]
            bk_col  = r["basket_col"]
            bvl_col = r["bvl_col"]
            sbs     = str(r["sbs_code"])
            bbg     = r["bbg_ticker"]
            sector  = gics.loc[bbg, "GICS"] if bbg in gics.index else "Index"
            empresa_nombre = gics.loc[bbg, "Empresa"] if bbg in gics.index else alias

            z_abs = row_bd.get(z_col, np.nan)
            z_bk  = row_bd.get(bk_col, np.nan) if bk_col in bd.columns else np.nan
            z_bvl = row_bd.get(bvl_col, np.nan) if bvl_col in bd.columns else np.nan

            if pd.isna(z_abs):
                continue

            # Tamaño de burbuja
            if pos_row is not None and sbs in pos_row.index and pd.notna(pos_row[sbs]):
                size = float(pos_row[sbs])
            else:
                size = 1500  # fallback para índices / sin posición

            puntos.append(dict(
                alias=alias,
                empresa=empresa_nombre,
                sector=sector,
                color=SECTOR_COLOR.get(sector, C["muted"]),
                z_abs=round(float(z_abs), 4),
                z_basket=round(float(z_bk), 4) if not pd.isna(z_bk) else None,
                z_bvl=round(float(z_bvl), 4) if not pd.isna(z_bvl) else None,
                size=round(size, 1),
            ))

        if puntos:
            bubble_by_date[fkey] = puntos

    return bubble_by_date


# ──────────────────────────────────────────────────────────────────────────────
# GRÁFICO 3 — HEATMAP DE RÉGIMEN (últimos 12 meses, frecuencia semanal)
# ──────────────────────────────────────────────────────────────────────────────

def build_heatmap_data(bd, param, gics):
    """
    Retorna matriz de Z-scores semanales para los últimos 12 meses.
    Filas = empresas, columnas = fechas semanales (viernes).
    """
    empresas = [
        r for _, r in param.iterrows()
        if str(r["z_col"]) in bd.columns and not str(r["z_col"]).startswith("nan")
        and "Index" not in str(r["z_col"])
    ]

    last_date = bd["Fecha"].max()
    start_date = last_date - pd.DateOffset(months=12)

    # Fechas semanales (viernes)
    fechas_semana = pd.date_range(start=start_date, end=last_date, freq="W-FRI")
    # Alinear cada viernes a la última fecha disponible en BD ≤ ese viernes
    bd_sorted = bd.sort_values("Fecha")

    heat_rows = []
    labels = []
    sectores = []
    empresas_nombres = []

    for r in empresas:
        alias   = r["alias"]
        z_col   = r["z_col"]
        bbg     = r["bbg_ticker"]
        sector  = gics.loc[bbg, "GICS"] if bbg in gics.index else "Other"
        nombre  = gics.loc[bbg, "Empresa"] if bbg in gics.index else alias

        serie = bd_sorted[["Fecha", z_col]].dropna(subset=[z_col]).set_index("Fecha")[z_col]
        if serie.empty:
            continue

        row_vals = []
        for viernes in fechas_semana:
            disponibles = serie[serie.index <= viernes]
            if disponibles.empty:
                row_vals.append(None)
            else:
                row_vals.append(round(float(disponibles.iloc[-1]), 4))

        # Solo incluir si tiene al menos 6 meses de datos en el período
        n_validos = sum(v is not None for v in row_vals)
        if n_validos < len(fechas_semana) // 2:
            continue

        heat_rows.append(row_vals)
        labels.append(alias)
        sectores.append(sector)
        empresas_nombres.append(nombre)

    fechas_str = [f.strftime("%Y-%m-%d") for f in fechas_semana]

    return dict(
        z=heat_rows,
        x=fechas_str,
        y=labels,
        sectores=sectores,
        empresas=empresas_nombres,
    )


