def _limpiar_vacios(df: pd.DataFrame) -> pd.DataFrame:
    for v in _VACIOS:
        df.replace(v, 0, inplace=True)
    return df


def LimpiandoCIQ(base: pd.DataFrame,
                  fechas_tri: pd.Series,
                  nombre: str) -> pd.DataFrame:
    """
    Extrae y limpia datos trimestrales de Capital IQ para un ticker.

    ESTRUCTURA ESPERADA DE LA HOJA (columnas de la empresa):
        Fila 2 (iloc[2]): nombres de métricas CIQ  → IQ_NI, IQ_TOTAL_REV, IQ_TOTAL_EQUITY, IQ_EBITDA
        Fila 4 (iloc[4]): nombre del ticker
        Fila 5+ (iloc[5:]): datos numéricos

    DIAGNÓSTICO AUTOMÁTICO:
        Si los nombres de columna no coinciden con los esperados, el script
        imprime las primeras 6 filas del bloque de la empresa para que puedas
        identificar la fila correcta y ajustar el offset en _FILA_NOMBRES_CIQ.
    """
    # Nombres CIQ esperados en las primeras 4 columnas de la empresa
    _NOMBRES_CIQ_ESPERADOS = ["IQ_NI", "IQ_TOTAL_REV", "IQ_TOTAL_EQUITY", "IQ_EBITDA"]

    data_emp = base.loc[:, base.iloc[4] == nombre]

    # ── Buscar la fila donde están los nombres CIQ ────────────────────────────
    # Intentamos filas 2, 3 y 1 (en ese orden de probabilidad).
    # Si ninguna contiene los nombres esperados, usamos fila 2 y mostramos
    # un diagnóstico para que el usuario pueda identificar el offset correcto.
    fila_nombres = None
    for fila_candidata in [2, 3, 1, 0]:
        candidatos = [str(v).strip() for v in data_emp.iloc[fila_candidata].tolist()[:4]]
        if any(n in candidatos for n in _NOMBRES_CIQ_ESPERADOS):
            fila_nombres = fila_candidata
            break

    if fila_nombres is None:
        # Diagnóstico: mostrar las primeras 7 filas para identificar la estructura
        print(f"\n  ⚠️  [{nombre}] No se encontraron nombres CIQ en filas 0-3.")
        print(f"      Primeras 7 filas del bloque (para diagnóstico):")
        for i in range(min(7, len(data_emp))):
            vals = [str(v)[:20] for v in data_emp.iloc[i].tolist()[:6]]
            print(f"        fila {i}: {vals}")
        fila_nombres = 2  # fallback al valor original

    columnas = data_emp.iloc[fila_nombres].tolist()

    # La fila de datos empieza justo después de la última fila de metadatos
    # (normalmente fila 5, pero puede variar si los nombres están en otra fila)
    fila_datos = max(fila_nombres + 1, 5)
    data_emp_ = data_emp.iloc[fila_datos:].copy()
    data_emp_.columns = columnas[:len(data_emp_.columns)]

    # ── Renombrar columnas que no coincidan exactamente ───────────────────────
    # Capital IQ a veces exporta con variaciones: "IQ_NET_INC", "NET_INC", etc.
    # Este mapa normaliza los nombres más comunes al estándar esperado.
    _ALIAS_CIQ = {
        # Net Income
        "IQ_NET_INC":          "IQ_NI",
        "NET_INCOME":          "IQ_NI",
        "IQ_NET_INCOME":       "IQ_NI",
        "NET_INC":             "IQ_NI",
        # Revenue
        "IQ_TOTAL_REVENUE":    "IQ_TOTAL_REV",
        "TOTAL_REVENUE":       "IQ_TOTAL_REV",
        "IQ_REV":              "IQ_TOTAL_REV",
        "REVENUE":             "IQ_TOTAL_REV",
        # Book Value / Equity
        "IQ_BOOK_VALUE":       "IQ_TOTAL_EQUITY",
        "IQ_COMMON_EQ":        "IQ_TOTAL_EQUITY",
        "TOTAL_EQUITY":        "IQ_TOTAL_EQUITY",
        "BOOK_VALUE":          "IQ_TOTAL_EQUITY",
        # EBITDA
        "IQ_EBITDA_REPORTED":  "IQ_EBITDA",
        "EBITDA":              "IQ_EBITDA",
    }
    data_emp_.columns = [
        _ALIAS_CIQ.get(str(c).strip(), str(c).strip())
        for c in data_emp_.columns
    ]

    # ── Extraer las 4 columnas CIQ (primeras 4 del bloque) ───────────────────
    data_ciq = data_emp_.iloc[:, :4].dropna(axis=0, how="all")
    data_ciq = data_ciq.fillna(0)

    # Verificar que tengamos los nombres correctos; si no, avisar con detalle
    cols_obtenidas = data_ciq.columns.tolist()
    faltantes = [n for n in _NOMBRES_CIQ_ESPERADOS if n not in cols_obtenidas]
    if faltantes:
        print(f"\n  ⚠️  [{nombre}] Columnas CIQ obtenidas: {cols_obtenidas}")
        print(f"      Faltan: {faltantes}")
        print(f"      → Renombrando por posición (orden esperado: IQ_NI, IQ_TOTAL_REV, IQ_TOTAL_EQUITY, IQ_EBITDA)")
        # Fallback: renombrar por posición si los nombres no coinciden
        rename_map = dict(zip(cols_obtenidas[:4], _NOMBRES_CIQ_ESPERADOS[:len(cols_obtenidas)]))
        data_ciq.rename(columns=rename_map, inplace=True)

    # ── Alinear con fechas trimestrales e indexar ─────────────────────────────
    n = min(len(fechas_tri), len(data_ciq))
    data_ciq = data_ciq.iloc[:n].copy()
    data_ciq.insert(0, "Fecha", fechas_tri.values[:n])
    data_ciq.set_index("Fecha", inplace=True)

    _limpiar_vacios(data_ciq)
    data_ciq = data_ciq.astype(np.float64)

    # Calcular forwards a 12 meses para las 4 métricas CIQ
    data_ciq = forwards_one_year(
        data_ciq,
        ["Fwd_IQ_NI", "Fwd_IQ_TOTAL_REV", "Fwd_IQ_TOTAL_EQUITY", "Fwd_IQ_EBITDA"]
    )

    return data_ciq


def LimpiandoBBG(base: pd.DataFrame,
                  fechas_diarias: pd.Series,
                  nombre: str) -> pd.DataFrame:
    """
    Extrae y limpia datos diarios de Bloomberg para un ticker.
    Replica exactamente LimpiandoBBG del notebook original.
    """
    data_emp = base.loc[:, base.iloc[4] == nombre]
    columnas = data_emp.iloc[2].tolist()
    data_emp_ = data_emp.iloc[5:].copy()
    data_emp_.columns = columnas

    # Las columnas BBG empiezan en posición 4
    data_bbg = data_emp_.iloc[:, 4:].dropna(axis=0, how="all")
    data_bbg = data_bbg.fillna(0)

    # Insertar fechas diarias — alinear por tamaño
    n = min(len(fechas_diarias), len(data_bbg))
    data_bbg = data_bbg.iloc[:n].copy()
    data_bbg.insert(0, "Fecha", fechas_diarias.values[:n])
    data_bbg.set_index("Fecha", inplace=True)

    _limpiar_vacios(data_bbg)
    data_bbg = data_bbg.apply(pd.to_numeric, errors="coerce").fillna(0)

    return data_bbg


def LimpiandoIndices(base: pd.DataFrame,
                      fechas_diarias: pd.Series,
                      nombre: str) -> pd.DataFrame:
    """
    Extrae y limpia datos de un índice bursátil.
    Replica exactamente LimpiandoIndices del notebook original.
    Los índices usan la fila 3 (no la 4) para identificar el nombre.
    """
    data_idx = base.loc[:, base.iloc[3] == nombre]
    columnas = ["PX_LAST", "Trail_PE", "Fwd_PE", "Trail_PS", "Fwd_PS",
                "Trail_PB", "Fwd_PB", "Trail_EVEBITDA", "Fwd_EVEBITDA"]
    data_idx = data_idx.iloc[5:].copy()
    data_idx.columns = columnas
    data_idx = data_idx.fillna(0)

    n = min(len(fechas_diarias), len(data_idx))
    data_idx = data_idx.iloc[:n].copy()
    data_idx.insert(0, "Fecha", fechas_diarias.values[:n])
    data_idx.set_index("Fecha", inplace=True)

    _limpiar_vacios(data_idx)
    data_idx = data_idx.astype(np.float64)

    return data_idx


