# ── Constantes de diseño para el PDF ─────────────────────────────────────────
# Mapeo de nombre interno de columna → título estético en el PDF
_TITULOS_MULT = {
    "Trail_PE":       "Trail P/E",
    "Fwd_PE":         "Forward P/E",
    "Trail_PS":       "Trail P/S",
    "Fwd_PS":         "Forward P/S",
    "Trail_PB":       "Trail P/B",
    "Fwd_PB":         "Forward P/B",
    "Trail_EVEBITDA": "Trail EV/EBITDA",
    "Fwd_EVEBITDA":   "Forward EV/EBITDA",
}

# Colores corporativos
_C_LINEA  = "#3e63ad"   # azul principal
_C_HIST   = "#00cdcd"   # cyan  → promedio histórico completo
_C_ANIO   = "#b0b0b0"   # gris  → promedio último año (~260 días hábiles)
_C_FONDO  = "white"

# Un múltiplo se grafica solo si al menos este porcentaje de sus valores
# son distintos de 0 y NaN dentro del horizonte de análisis.
# Esto evita mostrar plots planos vacíos (ej. EV/EBITDA en financieras).
_UMBRAL_DATOS = 0.05


def _prom_ultimo_anio(serie: pd.Series) -> float:
    """Promedio de los últimos ~260 puntos hábiles (≈ 1 año)."""
    return serie.iloc[-260:].mean() if len(serie) >= 260 else serie.mean()


def _tiene_datos(serie: pd.Series) -> bool:
    """
    True si la serie tiene suficientes valores reales para graficar.

    Un múltiplo se considera vacío cuando Bloomberg o CIQ no reportan
    esa métrica para la empresa (ej. EV/EBITDA en bancos y seguros).
    En ese caso el vector es mayoritariamente ceros o NaN y el plot
    resultaría plano y sin sentido — se omite.
    """
    limpios = serie.replace(0, np.nan).dropna()
    return len(limpios) / max(len(serie), 1) >= _UMBRAL_DATOS


def _formato_eje_x(ax, fecha_min, fecha_max):
    """
    Aplica formato 'Mmm-YY' al eje X (Apr-16, Jul-22, Jan-26).
    Ajusta el intervalo automáticamente según el horizonte temporal
    para evitar solapamiento de etiquetas.
    """
    import matplotlib.dates as mdates

    n_anios = (fecha_max - fecha_min).days / 365.25
    if n_anios > 8:
        intervalo = 6
    elif n_anios > 5:
        intervalo = 4
    else:
        intervalo = 3

    ax.xaxis.set_major_locator(mdates.MonthLocator(interval=intervalo))
    ax.xaxis.set_major_formatter(mdates.DateFormatter("%b-%y"))
    ax.tick_params(axis="x", rotation=90, labelsize=7)
    ax.set_xlim([fecha_min, fecha_max])


def _grafico_empresa(df_z: pd.DataFrame,
                     mult: dict,
                     empresa: str,
                     fecha_inicio: pd.Timestamp):
    """
    Construye la página del PDF para una empresa.

    Layout de la página:
        Fila 0  (ancho completo, 2 cols): Evolución Z-Score Compuesto
        Fila 1  col-0: Trail P/E       col-1: Forward P/E
        Fila 2  col-0: Trail P/S       col-1: Forward P/S
        Fila 3  col-0: Trail P/B       col-1: Forward P/B
        Fila 4  col-0: Trail EV/EBITDA col-1: Forward EV/EBITDA
                        ↑ estas dos filas SOLO aparecen si tienen datos reales

    Reglas:
      - Exactamente 2 subplots de múltiplos por fila.
      - El Z-score ocupa toda la fila superior (sin importar cuántos múltiplos haya).
      - Los múltiplos vacíos (>95% ceros/NaN) se omiten silenciosamente.
      - Cada múltiplo usa su propio horizonte temporal: si Trail_PS tiene datos
        desde 2011 y Fwd_PS solo desde 2018, cada uno arranca desde su primera
        fecha válida sin forzar un mínimo común.
      - Fondo blanco en figura y en todos los ejes.
      - Líneas de referencia:
            cyan  (--): promedio histórico completo de la serie
            gris  (--): promedio del último año disponible (~260 días hábiles)
      - Eje X: formato 'Mmm-YY' (Apr-16, Jul-22, Jan-26).
    """
    import matplotlib.pyplot as plt
    import matplotlib.gridspec as gridspec

    df_mult = mult[empresa]

    # ── Determinar qué múltiplos tienen datos reales ──────────────────────────
    # Se evalúa cada columna dentro del horizonte solicitado.
    # Se respeta el orden de _TITULOS_MULT (Trail antes de Fwd para cada ratio).
    multiplos_activos = [
        (col, titulo)
        for col, titulo in _TITULOS_MULT.items()
        if col in df_mult.columns and _tiene_datos(df_mult[col][fecha_inicio:])
    ]

    n_mult     = len(multiplos_activos)
    n_filas_m  = (n_mult + 1) // 2          # filas de múltiplos (2 por fila)
    n_filas    = 1 + n_filas_m              # fila Z + filas de múltiplos
    alto       = max(9, n_filas * 3.4)      # altura dinámica para que respiren

    # ── Crear figura con fondo blanco ─────────────────────────────────────────
    fig = plt.figure(figsize=(15, alto), facecolor=_C_FONDO)

    # Título de la empresa (arriba a la izquierda, fuera del grid)
    fig.text(0.01, 0.995, empresa, fontsize=12, fontweight="bold",
             va="top", ha="left", color="#1a1a2e")

    # Leyenda global (arriba a la derecha)
    import matplotlib.lines as mlines
    leyenda = [
        mlines.Line2D([], [], color=_C_HIST,  linestyle="--",
                      linewidth=2, label="Promedio Histórico"),
        mlines.Line2D([], [], color=_C_ANIO,  linestyle="--",
                      linewidth=2, label="Promedio Último Año"),
    ]
    fig.legend(handles=leyenda, loc="upper right", fontsize=8,
               frameon=True, framealpha=0.9)

    # ── GridSpec: 2 columnas, n_filas filas ───────────────────────────────────
    gs = gridspec.GridSpec(
        nrows=n_filas, ncols=2,
        figure=fig,
        hspace=0.72,    # espacio vertical entre filas
        wspace=0.28,    # espacio horizontal entre columnas
        top=0.93, bottom=0.04, left=0.06, right=0.97,
    )

    # ── Fila 0: Z-Score (ocupa las 2 columnas) ────────────────────────────────
    ax_z = fig.add_subplot(gs[0, :])
    ax_z.set_facecolor(_C_FONDO)

    col_z = f"Z_{empresa}"
    if col_z in df_z.columns:
        z_serie = df_z[col_z].replace(0, np.nan)
        # El Z-score arranca desde fecha_inicio o desde su primer dato válido
        z_desde = z_serie[fecha_inicio:].dropna()
        if not z_desde.empty:
            f_min_z = z_desde.index.min()
            f_max_z = z_serie.dropna().index.max()
            ax_z.plot(z_desde, color=_C_LINEA, linewidth=1.8)
            ax_z.axhline(0, color="#cccccc", linewidth=0.7, linestyle="-")
            _formato_eje_x(ax_z, f_min_z, f_max_z)

    ax_z.set_title("Evolución Z-Score Compuesto", fontsize=10,
                   fontweight="bold", pad=6)
    ax_z.tick_params(axis="y", labelsize=8)
    ax_z.spines[["top", "right"]].set_visible(False)

    # ── Filas 1+: Subplots de múltiplos (2 por fila) ─────────────────────────
    for i, (col, titulo) in enumerate(multiplos_activos):
        fila   = 1 + i // 2
        columna = i % 2

        ax = fig.add_subplot(gs[fila, columna])
        ax.set_facecolor(_C_FONDO)

        # Limpiar la serie: reemplazar 0 por NaN para no distorsionar promedios
        serie = df_mult[col][fecha_inicio:].replace(0, np.nan).dropna()

        if serie.empty:
            ax.set_visible(False)
            continue

        # Cada múltiplo usa su propio horizonte (primer/último dato válido)
        # Un múltiplo que solo tiene datos de 2018 a 2025 grafica exactamente eso,
        # sin forzar que arranque en 2016 ni que llegue hasta hoy si ya no hay data.
        f_min = serie.index.min()
        f_max = serie.index.max()

        ax.plot(serie, color=_C_LINEA, linewidth=1.5)
        ax.axhline(serie.mean(),          color=_C_HIST, linestyle="--", linewidth=1.6)
        ax.axhline(_prom_ultimo_anio(serie), color=_C_ANIO, linestyle="--", linewidth=1.6)

        _formato_eje_x(ax, f_min, f_max)
        ax.set_title(titulo, fontsize=9, fontweight="bold", pad=5)
        ax.tick_params(axis="y", labelsize=8)
        ax.spines[["top", "right"]].set_visible(False)

    # Ocultar el subplot vacío si n_mult es impar
    if n_mult % 2 != 0 and n_mult > 0:
        fila_vacia = 1 + (n_mult - 1) // 2
        ax_v = fig.add_subplot(gs[fila_vacia, 1])
        ax_v.set_visible(False)

    return fig


def generar_pdf(matriz_multiplos: dict,
                df_z_fin: pd.DataFrame,
                df_z_cc: pd.DataFrame,
                df_z_mu: pd.DataFrame,
                empresas_fin: list,
                empresas_cc: list,
                empresas_mu: list,
                fecha_hoy: str,
                ruta_pdf: str) -> None:
    """
    Genera el PDF corporativo de evolución de Z-scores y múltiplos.

    Una página por empresa, con:
      - Fondo blanco
      - Z-score en fila completa (superior)
      - Múltiplos de 2 en 2 por fila
      - Plots vacíos omitidos automáticamente (EV/EBITDA en financieras, etc.)
      - Eje X en formato 'Mmm-YY' (Apr-16, Jul-22, Jan-26)
      - Horizonte independiente por cada múltiplo
    """
    try:
        import matplotlib.pyplot as plt
        from matplotlib.backends.backend_pdf import PdfPages

        fecha_inicio = pd.Timestamp("2016-01-01")
        ruta_archivo = os.path.join(ruta_pdf, f"Evolucion Z y Multiplos {fecha_hoy}.pdf")

        grupos = [
            (empresas_fin, df_z_fin),
            (empresas_cc,  df_z_cc),
            (empresas_mu,  df_z_mu),
        ]

        with PdfPages(ruta_archivo) as pdf:
            for lista_emp, df_z in grupos:
                for empresa in lista_emp:
                    if empresa not in matriz_multiplos:
                        continue
                    fig = _grafico_empresa(df_z, matriz_multiplos, empresa, fecha_inicio)
                    # facecolor=fig.get_facecolor() garantiza que el PDF herede el fondo blanco
                    pdf.savefig(fig, facecolor=fig.get_facecolor())
                    plt.close(fig)

        print(f"  ✓ PDF generado: {ruta_archivo}")

    except Exception as e:
        print(f"  ✗ Error al generar PDF: {e}")
        print(f"    ¿Existe la carpeta? → {ruta_pdf}")


