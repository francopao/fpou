def leer_hoja_excel(ruta: str, hoja: str,
                    n_filas: int = 7600,
                    con_encabezado: bool = False) -> pd.DataFrame:
    """Lee una hoja Excel con dtype=object para evitar ArrowStringArray."""
    header = 0 if con_encabezado else None
    df = pd.read_excel(
        ruta, sheet_name=hoja,
        header=header, nrows=n_filas,
        engine="openpyxl", dtype=object,
    )
    if not con_encabezado:
        df.columns = [f"column_{i}" for i in range(len(df.columns))]
    return df


def escribir_df_en_excel(ruta: str, hoja: str,
                          df: pd.DataFrame,
                          incluir_indice: bool = True) -> None:
    """Sobreescribe el contenido de una hoja Excel preservando macros."""
    wb = load_workbook(ruta, keep_vba=True)
    if hoja in wb.sheetnames:
        ws = wb[hoja]
        ws.delete_rows(1, ws.max_row)
    else:
        ws = wb.create_sheet(hoja)

    df_exp = df.reset_index() if incluir_indice else df.reset_index(drop=True)

    for col_i, col_name in enumerate(df_exp.columns, start=1):
        ws.cell(row=1, column=col_i, value=str(col_name))

    for row_i, row in enumerate(df_exp.itertuples(index=False), start=2):
        for col_i, valor in enumerate(row, start=1):
            if isinstance(valor, (pd.Timestamp, datetime.datetime)):
                valor = valor.to_pydatetime() if isinstance(valor, pd.Timestamp) else valor
            elif isinstance(valor, (pd.Period,)):
                valor = str(valor)
            elif isinstance(valor, float) and np.isnan(valor):
                valor = None
            ws.cell(row=row_i, column=col_i, value=valor)

    wb.save(ruta)
    print(f"  ✓ Escrito: {os.path.basename(ruta)} → hoja '{hoja}'")


