def leer_baskets(ruta: str):
    """
    Lee la hoja Baskets y devuelve las 9 listas/dicts igual que el notebook.
    Retorna: (Todas_Finan, Empresas_Financieras, Basket_Financieras,
               Todas_Cons_Const, Empresas_Cons_Const, Basket_Cons_Const,
               Todas_Min_Utl, Empresas_Min_Utl, Basket_Min_Utl)
    """
    df = leer_hoja_excel(ruta, "Baskets", n_filas=100)
    df = df.dropna(axis=1, how="all")

    def _extraer_grupo(nombre_grupo):
        bloque = df[df.iloc[:, 0] == nombre_grupo].copy()
        bloque = bloque.drop(bloque.columns[0], axis=1)
        bloque = bloque.dropna(axis=1, how="all")

        todas = []
        empresas = []
        basket_dic = {}

        for _, fila in bloque.iterrows():
            vals = [v for v in fila.tolist() if pd.notna(v) and str(v).strip()]
            if not vals:
                continue
            empresa = vals[0]
            comparables = vals[1:]
            if empresa not in empresas:
                empresas.append(empresa)
            basket_dic[empresa] = comparables
            for t in [empresa] + comparables:
                if t not in todas:
                    todas.append(t)

        return todas, empresas, basket_dic

    todas_f,  emp_f,  basket_f  = _extraer_grupo("Financieras")
    todas_cc, emp_cc, basket_cc = _extraer_grupo("Con, Ind y HC")
    todas_mu, emp_mu, basket_mu = _extraer_grupo("Mineria y Utilities")

    return (todas_f,  emp_f,  basket_f,
            todas_cc, emp_cc, basket_cc,
            todas_mu, emp_mu, basket_mu)


