def Creacion_DF_Basket(basket: list,
                        matriz_multiplos: dict,
                        market_cap: pd.DataFrame,
                        fechas_diarias: pd.Index) -> pd.DataFrame:
    """
    Calcula el múltiplo ponderado por Market Cap del basket de comparables.
    Replica exactamente Creacion_DF_Basket del notebook original.
    """
    nombres_mult = [
        "Trail_PE", "Fwd_PE", "Trail_PS", "Fwd_PS",
        "Trail_PB", "Fwd_PB", "Trail_EVEBITDA", "Fwd_EVEBITDA"
    ]

    # Filtrar comparables que existan en la matriz
    basket_valido = [t for t in basket if t in matriz_multiplos]
    if not basket_valido:
        return pd.DataFrame(0, index=fechas_diarias, columns=nombres_mult)

    df_basket = pd.DataFrame(index=fechas_diarias)

    dfs = {m: pd.DataFrame(index=fechas_diarias) for m in nombres_mult}
    for ticker in basket_valido:
        for mult in nombres_mult:
            if mult in matriz_multiplos[ticker].columns:
                temp = pd.DataFrame(matriz_multiplos[ticker][mult])
                temp.rename(columns={mult: ticker}, inplace=True)
                dfs[mult] = pd.concat([dfs[mult], temp], axis=1, sort=False)

    # Pesos por Market Cap (solo comparables presentes en market_cap)
    mc_cols = [t for t in basket_valido if t in market_cap.columns]
    if not mc_cols:
        return pd.DataFrame(0, index=fechas_diarias, columns=nombres_mult)

    mc = market_cap[mc_cols]
    pesos = mc.div(mc.sum(axis=1), axis=0)

    for mult in nombres_mult:
        cols_disp = [c for c in mc_cols if c in dfs[mult].columns]
        if cols_disp:
            df_basket[mult] = pesos[cols_disp].multiply(dfs[mult][cols_disp]).sum(axis=1)
        else:
            df_basket[mult] = 0.0

    return df_basket


