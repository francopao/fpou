def actualizar_DQ_IN(df_qest: pd.DataFrame,
                     dq_in_bd: pd.DataFrame) -> pd.DataFrame:
    """
    Replica exactamente la función DQ_IN del notebook original.
    Toma las filas nuevas del QEST a partir de la última fecha registrada
    en la BD y las concatena.
    """
    LISTA_IN = [
        "Fondo", "Dato", "Fecha", "SBS",
        "302012200001", "300013200002", "300013200001", "300011100001",
        "300009100001", "302002100001", "302051100001", "312051100001",
        "3220512Q1094", "302029100001", "3220082A1040", "302008100002",
        "302072200001", "302845100002", "395833228291", "312039100001",
        "302043100001", "302043100002", "302032100002", "302030100001",
        "302061100001", "302011100001", "312011100001", "302107100001",
        "3021012171A1", "345874294721", "312025100001", "312034100001",
        "312026100001", "3020836W5029", "3220292P2083",
    ]

    # Eliminar las primeras 10 filas (metadatos QEST) y transponer
    df = df_qest.drop(df_qest.index[list(range(0, 10))])
    df = df.transpose()
    df = df.rename(columns={df.columns[0]: "Isins"})

    filtrada = df[df["Isins"].isin(LISTA_IN)].transpose()
    filtrada.columns = filtrada.iloc[0].tolist()
    filtrada = filtrada[1:]

    # Última fecha registrada en la BD (la más reciente)
    ultima_fecha_bd = dq_in_bd["Fecha"][::-1].iloc[0]
    print(f"  → DQ_IN: última fecha registrada = {ultima_fecha_bd}")

    # Buscar esa fecha en QEST de forma robusta (normalizar a date)
    ultima_norm = pd.Timestamp(ultima_fecha_bd).normalize()
    fechas_qest = filtrada["Fecha"].tolist()

    fechas_norm = []
    for f in fechas_qest:
        try:
            fechas_norm.append(pd.Timestamp(f).normalize() if f is not None and not isinstance(f, str) else None)
        except Exception:
            fechas_norm.append(None)

    if ultima_norm not in fechas_norm:
        validas = [f for f in fechas_norm if f is not None]
        rango = f"{validas[0].date()} → {validas[-1].date()}" if validas else "sin fechas válidas"
        raise ValueError(
            f"La fecha {ultima_norm.date()} no se encontró en DQ_IN de QEST. "
            f"Rango disponible: {rango}"
        )

    indice_inicio = fechas_norm.index(ultima_norm) + 9
    nuevas_filas = filtrada.iloc[indice_inicio:].reset_index(drop=True)
    nuevas_filas = nuevas_filas[
        nuevas_filas["Dato"].astype(str).str.contains(r"Q|PxQ", na=False)
    ]

    return pd.concat([dq_in_bd, nuevas_filas], ignore_index=True)


