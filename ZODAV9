def Z(prueba_z: pd.DataFrame, anios: int) -> pd.DataFrame:
    """
    Rolling Z-score con ventana de anios × 260 días hábiles.
    Replica exactamente la función Z() del notebook original.
    """
    prueba_z.index = pd.to_datetime(prueba_z.index)
    window = anios * 260
    media  = prueba_z.rolling(window=window, min_periods=window).mean()
    std    = prueba_z.rolling(window=window, min_periods=window).std()
    return (prueba_z - media) / std


def Creacion_Z_Final(prueba_z: pd.DataFrame, es_finan: bool) -> pd.Series:
    """
    Combina Z-scores de múltiples ventanas y múltiplos en un Z único.
    Replica exactamente Creacion_Z_Final del notebook original,
    incluyendo la lógica de es_finan para elegir los pesos de múltiplos.
    """
    matriz_zs = {}
    for i, anios in enumerate(ANIOS_Z):
        z_i = Z(prueba_z, anios) * PESOS_Z[i]
        matriz_zs[anios] = z_i

    # Sumar ventanas (igual que el notebook: fill_value=0 para no propagar NaN)
    z_acum = pd.DataFrame()
    for anios in ANIOS_Z:
        if z_acum.empty:
            z_acum = matriz_zs[anios]
        else:
            z_acum = z_acum.add(matriz_zs[anios], fill_value=0)

    # Encontrar la ventana más larga con peso != 0
    ubi_mayor = 0
    for idx, peso in enumerate(reversed(PESOS_Z)):
        if peso != 0:
            ubi_mayor = len(PESOS_Z) - 1 - idx
            break

    # Recortar desde donde esa ventana tiene datos (igual que el notebook)
    desde_aqui = matriz_zs[ANIOS_Z[ubi_mayor]].dropna(how="all").index
    if desde_aqui.empty:
        # Si no hay suficiente historia, buscar la ventana más corta disponible
        for anios in ANIOS_Z:
            desde = matriz_zs[anios].dropna(how="all").index
            if not desde.empty:
                desde_aqui = desde
                break

    if not desde_aqui.empty:
        z_acum = z_acum.loc[desde_aqui[0]:]

    # Ponderar por múltiplo y colapsar a una sola serie
    pesos_mult = PESOS_FINAN if es_finan else PESOS_EX_FINAN
    z_final = (z_acum * pesos_mult).sum(axis=1)
    return z_final


