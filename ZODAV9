# SECCIÓN 8: CÁLCULO DE MÚLTIPLOS (fiel al notebook original)
# ==============================================================================

def multiplos(activo: str,
              datos_bbg: dict,
              datos_ciq: dict,
              fechas_nuevas: pd.Index) -> pd.DataFrame:
    """
    Calcula los 8 múltiplos de valorización.
    Replica exactamente la función multiplos() del notebook original:
    - Convierte BBG diario a Period Q con dt.to_period('Q')
    - Divide con CIQ trimestral (también en Period Q)
    - Reasigna Fechas_Nuevas (el índice diario original) como índice final

    Esto produce una serie diaria donde cada día lleva el múltiplo
    del último trimestre cerrado de su período Q.
    """

    def _a_period_q(serie: pd.Series) -> pd.Series:
        """Convierte índice de una Serie a Period Q."""
        s = serie.reset_index()
        s.columns = ["Fecha", serie.name if serie.name else "val"]
        s["Fecha"] = s["Fecha"].dt.to_period("Q")
        s = s.set_index("Fecha").squeeze()
        return s

    def _bbg_q(col: str) -> pd.Series:
        return _a_period_q(datos_bbg[activo][col])

    def _ciq_q(col: str) -> pd.Series:
        s = datos_ciq[activo][col].copy()
        s.index = pd.DatetimeIndex(s.index).to_period("Q")
        return s

    def _ratio(num: pd.Series, den: pd.Series, nombre: str) -> pd.DataFrame:
        """Divide, reasigna fechas diarias y reemplaza inf por 0."""
        df = pd.DataFrame(num / den, columns=[nombre])
        df["Fecha"] = fechas_nuevas
        df = df.set_index("Fecha")
        df.replace([np.inf, -np.inf], 0, inplace=True)
        return df

    ev         = _bbg_q("CURR_ENTP_VAL")
    market_cap = _bbg_q("CUR_MKT_CAP")

    net_income = _ciq_q("IQ_NI")
    ventas     = _ciq_q("IQ_TOTAL_REV")
    book       = _ciq_q("IQ_TOTAL_EQUITY")
    ebitda     = _ciq_q("IQ_EBITDA")

    fwd_ni     = _ciq_q("Fwd_IQ_NI")
    fwd_ventas = _ciq_q("Fwd_IQ_TOTAL_REV")
    fwd_book   = _ciq_q("Fwd_IQ_TOTAL_EQUITY")
    fwd_ebitda = _ciq_q("Fwd_IQ_EBITDA")

    trail_pe      = _ratio(market_cap, net_income,  "Trail_PE")
    fwd_pe        = _ratio(market_cap, fwd_ni,      "Fwd_PE")
    trail_ps      = _ratio(market_cap, ventas,      "Trail_PS")
    fwd_ps        = _ratio(market_cap, fwd_ventas,  "Fwd_PS")
    trail_pb      = _ratio(market_cap, book,        "Trail_PB")
    fwd_pb        = _ratio(market_cap, fwd_book,    "Fwd_PB")
    trail_evebita = _ratio(ev,         ebitda,      "Trail_EVEBITDA")
    fwd_evebitda  = _ratio(market_cap, fwd_ebitda,  "Fwd_EVEBITDA")

    return pd.concat(
        [trail_pe, fwd_pe, trail_ps, fwd_ps,
         trail_pb, fwd_pb, trail_evebita, fwd_evebitda],
        axis=1
    )


