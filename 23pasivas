    State("store-custom-cols","data"),
    State("store-mgmt-map",   "data"),
)
def render_sum_table(rules, month, custom_cols, mgmt_map):
    rules = rules or []
    if not rules or not month:
        return html.Div()
    df = get_df(month, custom_cols or {}, mgmt_map or MANAGEMENT_MAP)
    if df.empty: return html.Div()

    rows_data, total = [], 0
    for r in rules:
        sc, fc, fv, lbl = r["sum_col"], r["filter_col"], r["filter_val"], r["label"]
        if sc not in df.columns or fc not in df.columns:
            rows_data.append({"Categoría": lbl, "Sumatoria": "col no encontrada"})
            continue
        mask = df[fc].astype(str) == fv
        try:
            s = pd.to_numeric(df.loc[mask, sc], errors="coerce").sum()
            total += s
            rows_data.append({"Categoría": lbl,
                               "Sumatoria": f"{s:,.2f}"})
        except:
            rows_data.append({"Categoría": lbl, "Sumatoria": "error"})

    rows_data.append({"Categoría": "TOTAL", "Sumatoria": f"{total:,.2f}"})

    tbl = dash_table.DataTable(
        data=rows_data,
