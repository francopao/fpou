def mes_anterior(mes_, anio):
    """Devuelve (mes_abrev, anio_str) del mes anterior."""
    n = meses_n[meses_.index(mes_)]
    if n == '01':
        mesA = '12'
        a = str(int(anio) - 1)
    else:
        mesA = str(int(n) - 1).zfill(2)
        a = anio
    return MONTHS_MAP[mesA], a


