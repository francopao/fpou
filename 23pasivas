    State("store-custom-cols",  "data"),
    State("store-recording",    "data"),
    State("store-macro-log",    "data"),
    prevent_initial_call=True,
)
def apply_custom_col(n, name, val, else_val, cols, ops, vals,
                     existing, recording, macro_log):
    if not n or not name:
        return no_update, "⚠ Ingresa un nombre de columna", no_update
    name = name.strip()
    conditions = []
    for c, o, v in zip(cols or [], ops or [], vals or []):
        if c:
            conditions.append({"col": c, "op": o or "=", "val": v or ""})
    existing = existing or {}
    existing[name] = {
        "value":      val or "",
        "else_val":   else_val or "",
        "conditions": conditions,
    }
    log = macro_log or []
    if recording:
        log = log + [
            f"ADD_COLUMN {name} VALUE {val or ''} ELSE {else_val or ''} "
            f"CONDITIONS {json.dumps(conditions)}"
        ]
    return existing, f"✓ Columna '{name}' creada", log

