def build_datasets():
    print("\n══ AFP Integra · Inversión Temática ══")

    print("→ Buscando archivo Inversión Temática...")
    inv_file = find_latest_xlsm(INVERSION_DIR)
    print(f"  ✓ {os.path.basename(inv_file)}")

    print("→ Calculando últimos 12 días hábiles de mes...")
    month_ends = get_12_month_ends()
    for d in month_ends:
        print(f"  {d.strftime('%B %Y')}: {d.strftime('%d/%m/%Y')}")

    print("→ Leyendo hoja Detallado...")
    det_df = read_detallado(BENCHMARKING_FILE)
    print(f"  ✓ {len(det_df)} filas · {len(det_df.columns)} cols")

    datasets = {}
    print("→ Leyendo Valorización por mes...")
    for d in month_ends:
        label = d.strftime("%m/%Y")
        print(f"  {label}...", end=" ", flush=True)
        df = read_valorizacion(inv_file, d)
        if not df.empty:
            df = merge_detallado(df, det_df)
            df = add_management(df)
            datasets[label] = df
            print(f"✓ {len(df)} filas")
        else:
            print("✗ vacío")

    print(f"\n✓ {len(datasets)} datasets listos\n")
    return datasets

