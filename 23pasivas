#  HELPER: obtener df del mes activo + custom cols aplicadas
# ══════════════════════════════════════════════════════════════════════
def get_df(month, custom_cols_store, mgmt_map_store):
    if not month or month not in DATASETS:
        return pd.DataFrame()
    df = DATASETS[month].copy()
    # Reaplicar management con mapa actualizado
    col_b = df.columns[0]
    df["Management"] = (
        df[col_b].astype(str).str[:2].str.upper()
        .map(mgmt_map_store).fillna("Unknown")
    )
    # Aplicar columnas custom
    for name, cfg in custom_cols_store.items():
        conditions = cfg.get("conditions", [])
        val_yes = cfg.get("value", "")
        val_no  = cfg.get("else_val", "")
        def apply_fn(row, conds=conditions, vy=val_yes, vn=val_no):
            for c in conds:
                rv = str(row.get(c["col"], "") or "")
                op, cv = c["op"], c["val"]
                if op == "=":          match = rv == cv
                elif op == "!=":       match = rv != cv
                elif op == "contains": match = cv.lower() in rv.lower()
                elif op == "starts":   match = rv.lower().startswith(cv.lower())
                elif op == ">":
                    try: match = float(rv) > float(cv)
                    except: match = False
                elif op == "<":
                    try: match = float(rv) < float(cv)
                    except: match = False
                else: match = False
                if not match: return vn
            return vy
        df[name] = df.apply(apply_fn, axis=1)
    return df

