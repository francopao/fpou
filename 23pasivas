def find_latest_xlsm(directory):
    patterns = [
        os.path.join(directory, "Inves*n Tematica*.xlsm"),
        os.path.join(directory, "Inves*Tematica*.xlsm"),
        os.path.join(directory, "*.xlsm"),
    ]
    files = []
    for p in patterns:
        files = glob.glob(p)
        if files: break
    if not files:
        raise FileNotFoundError(f"No se encontró .xlsm en:\n{directory}")
    def extract_dt(f):
        name = os.path.basename(f)
        m = re.search(r'(\d{6})', name)
        if m:
            s = m.group(1)
            try: return date(int(s[2:]), int(s[:2]), 1)
            except: pass
        return date.min
    return max(files, key=extract_dt)

def read_valorizacion(filepath, target_date):
    """Lee B:AS desde fila 3 (header). No refresca Power Query."""
    try:
        df = pd.read_excel(
            filepath,
            sheet_name=SHEET_VALORIZACION,
            header=2,        # fila 3 = índice 2
            usecols="B:AS",
            engine="openpyxl",
            dtype=str,
        )
        df = df.dropna(how="all")
        df["_fecha"] = target_date.strftime("%d/%m/%Y")
        return df
    except Exception as e:
        print(f"  [ERROR] Valorización: {e}")
        return pd.DataFrame()

def read_detallado(filepath):
    try:
        df = pd.read_excel(
            filepath,
            sheet_name=SHEET_DETALLADO,
            header=0,
            engine="openpyxl",
            dtype=str,
        )
        return df
    except Exception as e:
        print(f"  [ERROR] Detallado: {e}")
        return pd.DataFrame()

def merge_detallado(val_df, det_df):
    if val_df.empty or det_df.empty:
        return val_df
    det_cols = det_df.columns.tolist()
    col_b_det = det_cols[1] if len(det_cols) > 1 else None
    if col_b_det is None: return val_df

    sel_det = [det_cols[i] for i in DETALLADO_COLS_IDX if i < len(det_cols)]
    val_cols = val_df.columns.tolist()
    # col H de Valorización = índice 6 en B:AS (B=0,C=1,D=2,E=3,F=4,G=5,H=6)
    col_h_val = val_cols[6] if len(val_cols) > 6 else None
    if col_h_val is None: return val_df

    det_indexed = det_df.set_index(col_b_det)
    for sc in sel_det:
        if sc in det_indexed.columns:
            label = f"DET_{sc}"
            val_df[label] = val_df[col_h_val].map(
                lambda x, c=sc: det_indexed[c].get(x, None) if x in det_indexed.index else None
            )
    return val_df

def add_management(df):
    col_b = df.columns[0]
    df["Management"] = (
        df[col_b].astype(str).str[:2].str.upper()
        .map(MANAGEMENT_MAP).fillna("Unknown")
    )
    return df

