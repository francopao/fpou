    # ------------------------------------------------------------------
    # Función reutilizable: divide columnas numéricas /100  ← FIX CENTRAL
    # ------------------------------------------------------------------
    def dividir_por_100(df):
        cols_num = df.select_dtypes(include="number").columns
        df[cols_num] = df[cols_num] / 100
        return df

    # ------------------------------------------------------------------
    # Función reutilizable: renombrado con diccionario
    # ------------------------------------------------------------------
    def cargar_diccionario():
        df_ren = pd.read_excel(ruta_dict, sheet_name='Tasas')
        df_ren = df_ren.set_index("Nombre_Antiguo")
        return df_ren.to_dict()

    def aplicar_renombre(df, dic_ren):
        def dic_cambio_n(row):
            try:
                return dic_ren['Nombre_Nuevo'][row["Detallada"]]
            except Exception:
                return row["Detallada"]

        df["Detallada"] = df.apply(dic_cambio_n, axis=1)
        return df

    # ------------------------------------------------------------------
    # Función reutilizable: limpieza inicial del Excel SBS
    # ------------------------------------------------------------------
    def limpiar_df(df):
        for index, row in enumerate(df.iloc[:, 2]):
            if not pd.isnull(row):
                break
            df.drop(index, inplace=True)
        df.columns = df.iloc[0, :]
        df.drop(df.index[0], inplace=True)
        df = df.dropna(axis=1, how="all")
        df = df.loc[:, ~df.columns.duplicated()]
        return df

    # ------------------------------------------------------------------
    # Función reutilizable: transposición + renombre doble
    # ------------------------------------------------------------------
    def transponer_y_renombrar(df, dic_ren):
        df = aplicar_renombre(df, dic_ren)
        df = df.dropna(how="all")
        df = df.transpose().reset_index()
        df.columns = df.iloc[0, :]
        df = aplicar_renombre(df, dic_ren)
        df.drop(df.index[0], inplace=True)
        df = df.transpose().reset_index()
        df.columns = df.iloc[0, :]
        df.drop(df.index[0], inplace=True)
        df.iloc[:, 1:] = df.iloc[:, 1:].apply(pd.to_numeric, errors="coerce")
        return df

    # ------------------------------------------------------------------
    # Función reutilizable: armado del DF por tipos
    # ------------------------------------------------------------------
    def armar_por_tipos(df, tipos, n_hipotecarios=2):
        index_ = [df.loc[df['Detallada'].isin([t])].index[0] for t in tipos]

        DF_out = pd.DataFrame()
        for i in range(len(index_) - 1):
            df1 = df.loc[index_[i]:index_[i + 1]].copy()
            df1.insert(0, 'Tipo', tipos[i])
            df1 = df1.iloc[:9] if tipos[i] == "Microempresas" else df1.iloc[:7]
            DF_out = pd.concat([DF_out, df1]).sort_index(ignore_index=True)

        last_df = df.loc[index_[-1]:].copy()
        last_df.insert(0, 'Tipo', tipos[-1])
        last_df = last_df.iloc[:n_hipotecarios]
        DF_out = pd.concat([DF_out, last_df]).sort_index(ignore_index=True)

        for idx, row in DF_out.iterrows():
            if row['Detallada'] in tipos:
                DF_out.at[idx, 'Detallada'] = "Total"

        return DF_out.fillna(0)

