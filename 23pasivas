_FIXED_HOLIDAYS = {(1,1),(5,1),(6,29),(7,28),(7,29),(8,30),(10,8),(11,1),(12,8),(12,25)}

def _easter(year):
    a=year%19; b=year//100; c=year%100; d=b//4; e=b%4
    f=(b+8)//25; g=(b-f+1)//3; h=(19*a+b-d-g+15)%30
    i=c//4; k=c%4; l=(32+2*e+2*i-h-k)%7
    m=(a+11*h+22*l)//451
    month=(h+l-7*m+114)//31
    day=((h+l-7*m+114)%31)+1
    return date(year,month,day)

def _peru_holidays(year):
    h = set()
    for mo,da in _FIXED_HOLIDAYS:
        try: h.add(date(year,mo,da))
        except: pass
    e = _easter(year)
    h.add(e - timedelta(3)); h.add(e - timedelta(2))
    return h

def is_biz_day(d):
    return d.weekday() < 5 and d not in _peru_holidays(d.year)

def last_biz_day(year, month):
    if month == 12:
        nxt = date(year+1, 1, 1)
    else:
        nxt = date(year, month+1, 1)
    d = nxt - timedelta(1)
    while not is_biz_day(d):
        d -= timedelta(1)
    return d

def get_12_month_ends(ref=None):
    if ref is None: ref = date.today()
    m, y = ref.month - 1, ref.year
    if m == 0: m, y = 12, y-1
    result = []
    for _ in range(12):
        result.append(last_biz_day(y, m))
        m -= 1
        if m == 0: m, y = 12, y-1
    return list(reversed(result))

