# ── Ejecutar macro ────────────────────────────────────────────────────
@app.callback(
    Output("store-month",          "data", allow_duplicate=True),
    Output("store-custom-cols",    "data", allow_duplicate=True),
    Output("store-sum-rules",      "data", allow_duplicate=True),
    Output("macro-exec-log-wrap",  "children"),
    Output("macro-exec-log-wrap",  "style"),
    Input("btn-run-macro",         "n_clicks"),
    State("macro-input",           "value"),
    State("store-custom-cols",     "data"),
    State("store-sum-rules",       "data"),
    State("store-month",           "data"),
    prevent_initial_call=True,
)
def run_macro(n, code, custom_cols, sum_rules, current_month):
    if not n or not code: return no_update, no_update, no_update, "", {"display": "none"}

    lines = [l.strip() for l in code.split("\n")
             if l.strip() and not l.strip().startswith("//")]
    log_lines = []
    errors = 0
    new_month = current_month
    new_custom = dict(custom_cols or {})
    new_sums   = list(sum_rules or [])

    def log(msg, ok=True):
        nonlocal errors
        log_lines.append(("✓ " if ok else "✗ ") + msg)
        if not ok: errors += 1

    for i, line in enumerate(lines, 1):
        try:
            parts = line.split(" ", 1)
            cmd   = parts[0].upper()
            rest  = parts[1] if len(parts) > 1 else ""

            if cmd == "SELECT_MONTH":
                m = rest.strip()
                if m in DATASETS:
                    new_month = m; log(f"Mes {m} seleccionado")
                else:
                    log(f"Mes '{m}' no encontrado en datasets disponibles: {list(DATASETS.keys())}", False)

            elif cmd == "ADD_COLUMN":
                name_m = re.match(r'^(\S+)', rest)
                val_m  = re.search(r'VALUE (.+?) (ELSE|CONDITIONS|$)', rest)
                else_m = re.search(r'ELSE (.+?) (CONDITIONS|$)', rest)
                cond_m = re.search(r'CONDITIONS (.+)$', rest)
                if name_m:
                    name = name_m.group(1)
                    new_custom[name] = {
                        "value":      val_m.group(1).strip() if val_m else "",
                        "else_val":   else_m.group(1).strip() if else_m else "",
                        "conditions": json.loads(cond_m.group(1)) if cond_m else [],
                    }
                    log(f"Columna '{name}' creada")
                else:
                    log("ADD_COLUMN: nombre no válido", False)

            elif cmd == "SUM":
                sc_m  = re.search(r'col:(.+?) WHERE', rest)
                wh_m  = re.search(r'WHERE col:(.+?)=(.+?) LABEL', rest)
                lb_m  = re.search(r'LABEL (.+)$', rest)
                if sc_m and wh_m:
                    new_sums.append({
                        "sum_col":    sc_m.group(1).strip(),
                        "filter_col": wh_m.group(1).strip(),
                        "filter_val": wh_m.group(2).strip(),
                        "label":      lb_m.group(1).strip() if lb_m else wh_m.group(2).strip(),
                    })
                    log(f"Sumatoria agregada: {sc_m.group(1).strip()}")
                else:
                    log("SUM: sintaxis inválida. Usa: SUM col:X WHERE col:Y=Z LABEL L", False)

            elif cmd == "REAPPLY_MANAGEMENT":
                log("Management marcado para reaplicarse")

            elif cmd == "CLEAR_SUMS":
                new_sums = []; log("Sumatorias limpiadas")

            else:
                log(f"Comando desconocido en línea {i}: '{cmd}'", False)

        except Exception as e:
            log(f"Error en línea {i} ('{line[:40]}'): {e}", False)
            errors += 1

    summary = f"\n── {len(lines)} comandos · {errors} error(es) ──"
    log_lines.append(summary)
    log_content = html.Pre(
        "\n".join(log_lines),
        style={"background": BG, "border": f"1px solid {BORDER}",
               "borderRadius": "4px", "padding": "12px",
               "fontSize": "11px", "color": TEXT, "lineHeight": "1.9",
               "maxHeight": "200px", "overflowY": "auto",
               "fontFamily": FONT_MONO, "whiteSpace": "pre-wrap"},
    )
    wrap_style = {"display": "block", "marginTop": "12px"}
    return new_month, new_custom, new_sums, log_content, wrap_style

