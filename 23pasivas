            DF_1.insert(0, 'Institución', institucion)
            DF_1.insert(1, 'Estructura', estructura)
            DF_1.insert(6, fecha_col,    DF[a])
            DF_Base = pd.concat([DF_Base, DF_1])
        DF_Base.insert(0, 'key',
            DF_Base["Institución"] + DF_Base["Estructura"] + DF_Base["Moneda"] +
            DF_Base["Nombre"]      + DF_Base["Tipo"]       + DF_Base["Detallada"])
