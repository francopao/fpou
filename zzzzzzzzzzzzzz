# Peruvian public holidays (fixed + moveable approximations)
PERU_HOLIDAYS = {
    (1, 1), (5, 1), (6, 29), (7, 28), (7, 29),
    (8, 30), (10, 8), (11, 1), (12, 8), (12, 25),
    # Semana Santa approximations added dynamically
