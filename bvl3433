def escribir_en_excel(ruta: str, datos: dict) -> None:
    """
    Escribe DataFrames en hojas de un .xlsm/.xlsx preservando macros y formato.
    Usa openpyxl puro — sin xlwings, sin win32com, sin COM.

    'datos' es {nombre_hoja: (dataframe, celda_inicio, con_header, con_index)}
    celda_inicio como "A1" o "A2".
    """
    try:
        wb = load_workbook(ruta, keep_vba=True)   # keep_vba=True preserva las macros del .xlsm

        for nombre_hoja, (df, celda, con_header, con_index) in datos.items():
            ws = wb[nombre_hoja]

            # Parsear celda inicio (ej: "A2" → col=1, row=2)
            from openpyxl.utils.cell import coordinate_to_tuple
            fila_ini, col_ini = coordinate_to_tuple(celda)

            # Preparar datos a escribir (lista de listas)
            filas = []
            if con_header:
                encabezado = ([""] if con_index else []) + list(df.columns)
                filas.append(encabezado)
            for idx, row in df.iterrows():
                fila = ([idx] if con_index else []) + list(row)
                filas.append(fila)

            # Escribir celda a celda
            for r_offset, fila in enumerate(filas):
                for c_offset, valor in enumerate(fila):
                    # Convertir tipos no serializables
                    if hasattr(valor, "item"):        # numpy scalar → python nativo
                        valor = valor.item()
                    try:
                        if pd.isna(valor):
                            valor = None
                    except (TypeError, ValueError):
                        pass
                    ws.cell(row=fila_ini + r_offset,
                            column=col_ini + c_offset,  # openpyxl usa 'column', no 'col'
                            value=valor)

        wb.save(ruta)
        print(f"   ✓ Guardado: {os.path.basename(ruta)}")

    except Exception as e:
        print(f"   ✗ Error al escribir en Excel: {e}")
        print("     Continúa ejecución sin guardar este bloque.")


