def _limpiar_precios(df_raw: pd.DataFrame, tipo_campo: str,
                     fechas: pd.Series, fecha_corte=None) -> pd.DataFrame:
    """
    Extrae y limpia columnas de precio según el campo Bloomberg.
    Usa iloc puro para ser compatible con pd.read_excel(header=None),
    donde las columnas son enteros 0,1,2,... y el índice de fila también.
    Estructura esperada de df_raw (hoja RVL):
      fila 0: metadatos
      fila 1: metadatos
      fila 2: tipo de campo (ej: "TOT_RETURN_INDEX_GROSS_DVDS" o "Px_last")
      fila 3: ISINs / nombres de columna
      fila 4: metadatos
      fila 5+: datos de precios; columna 0 = metadata, columna 2 = fechas
    """
    # Seleccionar columnas cuyo campo en fila 2 coincide con tipo_campo
    mascara = df_raw.iloc[2, :] == tipo_campo
    sub = df_raw.loc[:, mascara].copy()

    # Extraer nombres de columna desde fila 3 (ISINs), omitir primera col si aplica
    cols = df_raw.iloc[3, mascara].tolist()

    # Datos desde fila 5
    sub = df_raw.iloc[5:, mascara].copy()
    sub.columns = cols
    sub = sub.loc[:, ~pd.Index(cols).isna()]
    sub = sub.loc[:, ~sub.columns.duplicated()]

    sub.insert(0, "Fecha", fechas.values)
    sub.set_index("Fecha", inplace=True)
    sub.replace(["#N/A N/A", "NM", "(Invalid Formula Name)", "NA"], np.nan, inplace=True)
    sub.bfill(inplace=True)
    sub = sub.fillna(0)
    for col in sub.select_dtypes(include="object").columns:
        sub[col] = pd.to_numeric(sub[col], errors="coerce").fillna(0).astype("float64")
    if fecha_corte is not None:
        sub = sub.loc[:fecha_corte].copy()
    return sub


