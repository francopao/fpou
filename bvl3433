def _weights(pxq_df: pd.DataFrame, cols=None) -> pd.DataFrame:
    sub = pxq_df[cols] if cols is not None else pxq_df
    return sub.div(sub.sum(axis=1), axis=0)


def _rezagar(w: pd.DataFrame) -> pd.DataFrame:
    """Desplaza el índice un período hacia adelante (weight t-1 → ret t)."""
    w = w.copy()
    w.index = w.reset_index(names="Fecha")["Fecha"].shift(-1)
    return w.iloc[:-1]


def _build_weights(pxq_map: dict, sufijo: str = "", cols=None) -> dict:
    out = {}
    for key, pxq in pxq_map.items():
        w = _rezagar(_weights(pxq, cols))
        out[f"{key}{sufijo}"] = w
    return out


