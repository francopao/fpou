colors      = ["#3e63ad", "#00B0F0", "#FF0000", "#FFA500"]
labels_afp  = ["Integra", "Habitat", "Profuturo", "Prima"]
afps_claves = ["IN", "HA", "PF", "RI"]
FONT        = "Trebuchet MS"
TAMFONT     = 10


def _formato_eje(ax, rotacion: int = 90, fmt: str = "%d-%b-%y"):
    ax.tick_params(axis="x", rotation=rotacion, labelsize=TAMFONT)
    ax.tick_params(axis="y", labelsize=TAMFONT)
    ax.xaxis.set_major_formatter(mdates.DateFormatter(fmt))


def _titulo_ax(ax, titulo: str, fontsize: int = 12):
    ax.set_title(titulo)
    ax.title.set_fontsize(fontsize)
    ax.title.set_fontname(FONT)


def _plot_portafolio_fondo(ax, df_fondo: pd.DataFrame, titulo: str, solo_integra: bool = False):
    ax.plot(EPU_Var_Acum,     color="grey",    label="EPU")
    ax.plot(ETFPERU_Var_Acum, color="green",   label="ETF Peru")
    for i, (afp, color, lbl) in enumerate(zip(afps_claves, colors, labels_afp)):
        if solo_integra and afp != "IN":
            continue
        if afp in df_fondo.columns:
            ax.plot(df_fondo[afp], color=color, label=lbl)
    _titulo_ax(ax, titulo)
    ax.legend(fontsize=8)
    _formato_eje(ax)


def Sectores_graph(
    Solo_Totales_Retornos_Sectoriales: dict,
    Precios_Con_Dividendos_R: pd.DataFrame,
    pdf_path: str,
    solo_integra: bool = False,
):
    """
    Genera el PDF de rendimientos RVL.
    solo_integra=True → solo pinta la línea de Integra (versión 'reducida').
    """
    with PdfPages(pdf_path) as pdf:

        # ── Portafolio total ──────────────────────────────────────────────────
        fig, axes = plt.subplots(2, 2, figsize=(22, 17))
        fig.suptitle("Rendimientos Acumulados – Portafolio RVL",
                     fontsize=20, fontweight="bold", color="#000000")
        plt.tight_layout(pad=5)
        plt.subplots_adjust(top=0.95)

        fondo_ax_map = {"F1": axes[0, 0], "F2": axes[0, 1], "F3": axes[1, 0], "M": axes[1, 1]}
        fondo_titulo = {"F1": "Fondo 1", "F2": "Fondo 2", "F3": "Fondo 3", "M": "Multifondo"}

        for fondo, ax in fondo_ax_map.items():
            df_fondo = Retornos_Agregados_Acum_RVL_Totales.get(fondo, pd.DataFrame())
            _plot_portafolio_fondo(ax, df_fondo, fondo_titulo[fondo], solo_integra)

        pdf.savefig(fig)
        plt.close(fig)

        # ── Por sectores ──────────────────────────────────────────────────────
        for sector in Lista_Sectores:
            fig, axes = plt.subplots(2, 2, figsize=(22, 17))
            titulo_sec = "Rendimiento: " if solo_integra else "Rendimiento Acumulado: "
            fig.suptitle(f"{titulo_sec}{sector}",
                         fontsize=20, fontweight="bold", color="#000000")
            plt.tight_layout(pad=5)
            plt.subplots_adjust(top=0.95)

            for fondo, ax in fondo_ax_map.items():
                key = f"{sector}_{fondo}"
                df_sec = Solo_Totales_Retornos_Sectoriales.get(key, pd.DataFrame())
                _plot_portafolio_fondo(ax, df_sec, fondo_titulo[fondo], solo_integra)

            pdf.savefig(fig)
            plt.close(fig)

        # ── Precios (8 por página) ────────────────────────────────────────────
        cols_validas = [c for c in Precios_Con_Dividendos_R.columns if c in Diccionario_Parametria]
        paginas      = len(cols_validas) // 8
        contador     = 0

        for _ in range(paginas + 1):
            fig, axes = plt.subplots(4, 2, figsize=(22, 17))
            fig.suptitle("Precios", fontsize=20, fontweight="bold", color="#000000")
            plt.tight_layout(pad=5)
            plt.subplots_adjust(top=0.95)

            for y in range(4):
                for x in range(2):
                    if contador == len(cols_validas):
                        axes[y, x].axis("off")
                        continue
                    col = cols_validas[contador]
                    axes[y, x].plot(Precios_Con_Dividendos_R[col], color="#3e63ad")
                    _titulo_ax(axes[y, x], Diccionario_Parametria[col])
                    axes[y, x].tick_params(axis="x", rotation=90, labelsize=12)
                    axes[y, x].tick_params(axis="y", labelsize=12)
                    axes[y, x].xaxis.set_major_formatter(mdates.DateFormatter("%b-%y"))
                    contador += 1

            pdf.savefig(fig)
            plt.close(fig)

    print(f"   ✓ PDF generado: {pdf_path}")


# ── Ejecutar generación del PDF completo ──────────────────────────────────────
Sectores_graph(
    Solo_Totales_Retornos_Sectoriales,
    Precios_Con_Dividendos_R,
    PDF_COMPLETO,
    solo_integra=False,
)

