def DQ_IN(df1: pd.DataFrame, DQ_IN_BD: pd.DataFrame,
          ListaIN: list, ListaUsados: list) -> pd.DataFrame:
    """
    Actualiza la base DQ_IN con los nuevos datos de QEST.
    Busca desde la última fecha disponible en la BD hacia adelante.
    """
    df1 = df1.drop(df1.index[list(range(0, 10))])
    df1 = df1.transpose().rename(columns={10: "Isins"})
    filtrada = df1[df1["Isins"].isin(ListaIN)].transpose()
    filtrada.columns = filtrada.iloc[0].tolist()
    filtrada = filtrada[1:]

    ultima_fecha = DQ_IN_BD["Fecha"][::-1].iloc[0]
    print(f"   DQ IN – última fecha BD: {ultima_fecha}")

    fechas_qest = filtrada["Fecha"].values.tolist()
    ubi = fechas_qest.index(ultima_fecha) + 9
    nuevos = filtrada[ubi:].reset_index(drop=True)
    nuevos = nuevos.loc[nuevos["Dato"] == "Q"]

    return pd.concat([DQ_IN_BD, nuevos], ignore_index=True)


def DQ_SIS(df2: pd.DataFrame, DQ_SIS_BD: pd.DataFrame,
           ListaEx: list) -> pd.DataFrame:
    """
    Actualiza la base DQ_SIS (sistema / competencia) con datos de QEST.

    FIX v2026: La hoja DQ_RV del QEST tiene DOS bloques:
      - Bloque 1 (filas 0-11):  cantidades por fondo (HA-FONDO1, PF-FONDO1…)
      - Bloque 2 (filas 12+):   datos de sistema con header en fila 15

    El código original usaba rename({13: 'Isins'}) apuntando a la fila de
    nombres de empresa, no a los ISINs. Con los archivos actuales la fila
    de ISINs/Fondo_Fecha está en la posición 15, por lo que se detecta
    dinámicamente buscando la fila que contiene 'Fondo_Fecha'.
    """
    # ── Paso 1: eliminar encabezado del bloque 1 y transponer ────────────────
    df3 = df2.drop(df2.index[list(range(0, 11))]).transpose()

    # ── Paso 2: detectar dinámicamente qué columna del transpose tiene ISINs ─
    # Buscamos la columna cuyo valor en alguna posición sea 'Fondo_Fecha'
    col_isins = None
    for col in df3.columns:
        if "Fondo_Fecha" in df3[col].values:
            col_isins = col
            break
    if col_isins is None:
        raise ValueError(
            "DQ_SIS: No se encontró la columna 'Fondo_Fecha' en DQ_RV del QEST. "
            "Verificar estructura del archivo."
        )
    df3 = df3.rename(columns={col_isins: "Isins"})

    # ── Paso 3: filtrar columnas que coinciden con ListaEx y transponer ───────
    filtrada_sis = df3[df3["Isins"].isin(ListaEx)].transpose()
    filtrada_sis = filtrada_sis.reset_index(drop=True).dropna(how="all")

    # ── Paso 4: encontrar dinámicamente la fila de header (Fondo_Fecha) ──────
    header_row = None
    for i in range(min(10, len(filtrada_sis))):
        if "Fondo_Fecha" in filtrada_sis.iloc[i].tolist():
            header_row = i
            break
    if header_row is None:
        raise ValueError(
            "DQ_SIS: No se encontró la fila de encabezado (Fondo_Fecha) "
            "en los datos filtrados. Verificar ListaEx e ISINs del QEST."
        )

    filtrada_sis.columns = filtrada_sis.iloc[header_row].tolist()
    filtrada_sis = filtrada_sis.iloc[header_row + 1:].copy()
    if "Fondo" in filtrada_sis.columns:
        filtrada_sis = filtrada_sis.drop(columns=["Fondo"])

    # ── Paso 5: identificar última fecha en el BD histórico ───────────────────
    DQ_SIS_BD.columns = DQ_SIS_BD.iloc[0].tolist()
    BD_H  = DQ_SIS_BD.drop(0)
    BD_HF = BD_H[2:]

    ultima_fecha = pd.Timestamp(BD_HF["Fecha"][::-1].drop_duplicates().iloc[0])
    print(f"   DQ SIS – última fecha BD: {ultima_fecha.date()}")

    # ── Paso 6: encontrar posición de corte en el QEST ───────────────────────
    # Convertir a Timestamp para comparación homogénea
    fechas_qest_ts = pd.to_datetime(
        filtrada_sis["Fecha"].values, errors="coerce"
    )

    if ultima_fecha in fechas_qest_ts:
        # Caso normal: la última fecha del BD existe en el QEST → tomar desde ahí
        ubi = list(fechas_qest_ts).index(ultima_fecha)
    else:
        # La última fecha del BD es anterior a todos los datos del QEST
        # → todos los registros del QEST son nuevos → agregar desde el inicio
        min_fecha_qest = fechas_qest_ts.dropna().min()
        if ultima_fecha < min_fecha_qest:
            print(f"   DQ SIS – BD ({ultima_fecha.date()}) anterior al QEST "
                  f"({min_fecha_qest.date()}): se agregan todos los registros nuevos.")
            ubi = 0
        else:
            # Tomar el primer registro posterior a ultima_fecha
            mask = fechas_qest_ts > ultima_fecha
            ubi = int(mask.argmax()) if mask.any() else len(fechas_qest_ts)

    nuevos   = filtrada_sis.iloc[ubi:].reset_index(drop=True).dropna(how="all")
    BD_Final = BD_H.iloc[:ubi if ubi > 0 else len(BD_H)]   # si ubi=0, tomar BD completo
    BD_Final = BD_Final.loc[:, ~BD_Final.columns.duplicated()]
    nuevos   = nuevos.loc[:,   ~nuevos.columns.duplicated()]

    return pd.concat([BD_Final, nuevos], ignore_index=True)


