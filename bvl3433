    "Ret_HA_F1_O_IL": Ret_HA_F1_O_IL, "Ret_HA_F2_O_IL": Ret_HA_F2_O_IL,
    "Ret_HA_F3_O_IL": Ret_HA_F3_O_IL, "Ret_HA_M_O_IL":  Ret_HA_M_O_IL,
    "Ret_PF_F1_O_IL": Ret_PF_F1_O_IL, "Ret_PF_F2_O_IL": Ret_PF_F2_O_IL,
    "Ret_PF_F3_O_IL": Ret_PF_F3_O_IL, "Ret_PF_M_O_IL":  Ret_PF_M_O_IL,
    "Ret_RI_F1_O_IL": Ret_RI_F1_O_IL, "Ret_RI_F2_O_IL": Ret_RI_F2_O_IL,
    "Ret_RI_F3_O_IL": Ret_RI_F3_O_IL, "Ret_RI_M_O_IL":  Ret_RI_M_O_IL,
    "Ret_EXSIS_F1_O_IL": Ret_EXSIS_F1_O_IL, "Ret_EXSIS_F2_O_IL": Ret_EXSIS_F2_O_IL,
    "Ret_EXSIS_F3_O_IL": Ret_EXSIS_F3_O_IL,
}

# ── Acumulados ─────────────────────────────────────────────────────────────────
Retornos_Agregados_Acum_RVL = {k: _acumular(v) for k, v in Retornos_Agregados_RVL.items()}
Ret_Acum_ETFs               = {k: _acumular(v) for k, v in Ret_ETFs.items()}


def _detectar_sufijo(nombre: str) -> str:
    low = nombre.lower()
    if any(t in low for t in ["_il", "_iliq", "ilíquida", "iliquida"]):
        return "_IL"
    if any(t in low for t in ["_o_l", "_liq", "liquida", "líquida"]):
        return "_L"
    return ""


# Totales por fondo (IN, HA, PF, RI por F1/F2/F3/M)
Nombres_Fondos_ind = ["F1", "F2", "F3", "M"]
Retornos_Agregados_Acum_RVL_Totales: dict[str, pd.DataFrame] = {f: pd.DataFrame() for f in Nombres_Fondos_ind}

for nombre, df in Retornos_Agregados_Acum_RVL.items():
    partes = nombre.split("_")
    if len(partes) < 3:
        continue
    afp   = partes[1]          # IN/HA/PF/RI/EXSIS
    ftag  = partes[2]          # F1/F2/F3/M
    if ftag not in Nombres_Fondos_ind:
        continue
    suf      = _detectar_sufijo(nombre)
    col_name = f"{afp}{suf}"
    Retornos_Agregados_Acum_RVL_Totales[ftag] = Retornos_Agregados_Acum_RVL_Totales[ftag].join(
        df[["Total"]].rename(columns={"Total": col_name}), how="outer"
    )


# ── Retornos por Sector ────────────────────────────────────────────────────────

Retornos_Weighted_Sectores_AFP: dict[str, pd.DataFrame] = {}
Retornos_Acumulados_Sectorial:  dict[str, pd.DataFrame] = {}

for fondo_dict in Lista_Weights_Sectores_Fondos:
    for afp_sector, weights in fondo_dict.items():
        key      = f"Ret_{afp_sector}"
        ret_raw  = Precios_Con_Dividendos_Var.mul(weights, axis=0).dropna(axis=0, how="all").dropna(axis=1, how="all")
        ret_raw["Total"] = ret_raw.sum(axis=1)
        Retornos_Weighted_Sectores_AFP[key]        = ret_raw
        Retornos_Acumulados_Sectorial[f"Ret_Acum_{afp_sector}"] = _acumular(ret_raw)

# Totales sectoriales por fondo
Solo_Totales_Retornos_Sectoriales: dict[str, pd.DataFrame] = {}
for sector in Lista_Sectores:
    for nombre, acum in Retornos_Acumulados_Sectorial.items():
        partes = nombre.split("_")
        if len(partes) < 5:
            continue
        fondo_tag = partes[4]
        afp_tag   = partes[2]
        sec_tag   = partes[3]
        key       = f"{sector}_{fondo_tag}"
        Solo_Totales_Retornos_Sectoriales.setdefault(key, pd.DataFrame())
        if sec_tag == sector:
            col_total = pd.DataFrame({afp_tag: acum["Total"]})
            Solo_Totales_Retornos_Sectoriales[key] = pd.concat(
                [Solo_Totales_Retornos_Sectoriales[key], col_total], axis=1
            )


# ── Exportar todo a Excel (hoja BD) ───────────────────────────────────────────

print("   Preparando DataFrame final para exportar a Excel...")
df_exportar = []

for i, df in Retornos_Agregados_RVL.items():
    ren = df.copy()
    ren.columns = [f"{i}_{col}" for col in ren.columns]
    df_exportar.append(ren)

ren_precios = Precios_Con_Dividendos_Var.copy()
ren_precios.columns = [f"Retorno_Precios_No_Acum_{c}" for c in ren_precios.columns]
df_exportar.append(ren_precios)

Totales_AUM_RVL = {k: PxQ[k] for k in PxQ}
PD_Final = pd.DataFrame({f"AUM_RVL_{k}": v.sum(axis=1) for k, v in Totales_AUM_RVL.items()})
df_exportar.append(PD_Final)

Matriz_Weights = {**{f"weight_{k}_": Weights[k] for k in Weights},
                  **{f"weight_{k}_L_": Weights_L[k] for k in Weights_L},
                  **{f"weight_{k}_IL_": Weights_IL[k] for k in Weights_IL}}

for i, df in Matriz_Weights.items():
    ren = df.iloc[:-1].copy()
    ren.columns = [f"{i}{col}" for col in ren.columns]
    df_exportar.append(ren)

for i, df in {**Ret_ETFs, **weights_etfs}.items():
    ren = df.copy()
    ren.columns = [f"{i}_{col}" for col in ren.columns]
    df_exportar.append(ren)

ren_retVP = Retornos_VP.copy()
ren_retVP.columns = [f"Retorno_VP_{c}" for c in ren_retVP.columns]
df_exportar.append(ren_retVP)

df_final = pd.concat(df_exportar, axis=1)

escribir_en_excel(
