def calculo_Aum(df: pd.DataFrame, fondos: list, afps: list) -> pd.DataFrame:
    """
    Calcula AUM y Market Share de cada AFP por fondo.

    FIX v2026: Con pd.read_excel(header=None, usecols="B:V") los índices de
    columna preservan los números de Excel (1-based), y la estructura del
    archivo tiene una fila extra de nombres de AFP (HABITAT, INTEGRA…) antes
    del header real (Fecha, IN-FONDO1…). Se detecta dinámicamente la fila
    header buscando la que contiene "Fecha" y etiquetas "FONDO".
    """
    # Resetear columnas a 0-based para trabajar con iloc de forma predecible
    df = df.copy()
    df.columns = range(len(df.columns))

    # Detectar fila header dinámicamente (contiene "Fecha" y "FONDO")
    header_row = None
    for i in range(min(20, len(df))):
        vals = df.iloc[i].tolist()
        if "Fecha" in vals and any("FONDO" in str(v) for v in vals):
            header_row = i
            break
    if header_row is None:
        raise ValueError(
            "calculo_Aum: No se encontró la fila header (Fecha + FONDO) "
            "en las primeras 20 filas del AUM. Verificar estructura del archivo."
        )

    # Transponer desde la fila header para filtrar por etiqueta AFP-FONDOn
    df_temp = df[header_row:].transpose()
    col_header = header_row  # en el transpose esta columna = fila header original

    lista_df = []
    for fondo in fondos:
        for afp in afps:
            lista_aum = ["Fecha", f"{afp}-FONDO{fondo}"]
            filtro = df_temp[df_temp[col_header].isin(lista_aum)]
            filtro_T = filtro.transpose()

            # Asignar columnas desde la fila que tiene el header real (loc, no iloc)
            filtro_T.columns = filtro_T.loc[col_header].tolist()
            filtro_T = filtro_T.drop(col_header)

            # Eliminar filas donde Fecha es NaN (filas de agrupadores AFP)
            filtro_T = filtro_T.dropna(subset=["Fecha"])
            filtro_T["Fecha"] = pd.to_datetime(filtro_T["Fecha"], errors="coerce")
            filtro_T = filtro_T.dropna(subset=["Fecha"])
            filtro_T.set_index("Fecha", inplace=True)
            filtro_T = filtro_T.set_axis([f"{afp}_F{fondo}"], axis=1)
            filtro_T = filtro_T["2014-12-30":]
            filtro_T = filtro_T.replace("ND", 0).fillna(0).astype(np.float64)
            lista_df.append(filtro_T)

    df_final = pd.concat(lista_df, axis=1)

    # Cálculo del Market Share de cada AFP
    df_final["Total"] = df_final.sum(axis=1)
    for afp in afps:
        df_final[f"{afp}_MF"]    = df_final.filter(like=f"{afp}_F").sum(axis=1)
        df_final[f"{afp}_Share"] = df_final[f"{afp}_MF"] / df_final["Total"]

    # Cálculo de AUM Ex-Sistema de cada AFP
    combinaciones = {
        "EXIN": ["HA", "PF", "RI"],
        "EXHA": ["IN", "PF", "RI"],
        "EXPF": ["IN", "HA", "RI"],
        "EXRI": ["IN", "PF", "HA"],
    }
    for fondo in fondos:
        for nuevo_col, cols in combinaciones.items():
            df_final[f"{nuevo_col}_F{fondo}"] = df_final[
                [f"{c}_F{fondo}" for c in cols]
            ].sum(axis=1)

    # AUM total por AFP (suma de fondos 1+2+3)
    for afp in afps:
        df_final[f"Aum_{afp}"] = sum(df_final[f"{afp}_F{f}"] for f in fondos)

    df_final.drop(columns=["Total"], inplace=True)
    return df_final


